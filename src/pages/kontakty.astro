---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { SITE } from '@lib/constants';
---

<BaseLayout
  title="Связаться со мной"
  description="Контакты Влада Вулкана — независимого консультанта по недвижимости в Эквадоре. Telegram, рабочие часы, форматы и география работы."
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'Контакты', href: '/kontakty' }]} />

    <article class="page">
      <h1>Связаться со мной</h1>
      <p class="lead">
        Главный канал — Telegram. Отвечаю в&nbsp;течение 24&nbsp;часов в&nbsp;рабочие дни.
      </p>

      <div class="contact-card">
        <div>
          <div class="ch-label">Telegram</div>
          <div class="ch-value">{SITE.telegramHandle}</div>
          <div class="ch-help">Главный канал. Кратко опишите ситуацию — отвечу в&nbsp;течение 24&nbsp;часов.</div>
        </div>
        <a href={SITE.telegramUrl} class="btn btn-primary" rel="noopener">Написать в Telegram</a>
      </div>

      <div class="contact-card">
        <div>
          <div class="ch-label">Email</div>
          <div class="ch-value">{SITE.email}</div>
          <div class="ch-help">Для документов и&nbsp;официальной переписки.</div>
        </div>
        <a href={`mailto:${SITE.email}`} class="btn btn-secondary">Написать на email</a>
      </div>

      <div class="contact-card">
        <div>
          <div class="ch-label">YouTube</div>
          <div class="ch-value">@vladvulkan (TBA)</div>
          <div class="ch-help">Обзоры объектов, аналитика рынков ЛатАм. Скоро запуск.</div>
        </div>
        <a href={SITE.youtubeUrl} class="btn btn-secondary" rel="noopener">Открыть канал</a>
      </div>

      <section class="section">
        <h2>Форматы работы</h2>
        <ul class="bullet-list">
          <li><strong>Стратегическая консультация</strong> — 60 минут в Zoom, $150. Засчитывается в пакет, если идём дальше.</li>
          <li><strong>Сопровождение сделки</strong> — фикс-пакет от $3000 (бюджет до $120K) или гибридная модель.</li>
          <li><strong>Проверка объекта</strong> — $1500 фикс. Вы нашли объект сами — я проверяю и веду торг.</li>
        </ul>
      </section>

      <section class="section">
        <h2>География работы</h2>
        <p class="text">
          Куэнка, Кито, Гуаякиль, Салинас, Манта — основная зона. Другие города — обсуждаем индивидуально,
          если объект и бюджет того стоят.
        </p>
      </section>

      <section class="section">
        <h2>Рабочие часы</h2>
        <p class="text">
          Будние дни, 09:00–18:00 по&nbsp;Куэнке (UTC−5). Это 17:00–02:00 МСК. Звонки и&nbsp;консультации — по&nbsp;записи через Telegram.
        </p>
      </section>

      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 8px 0 40px; }
  .page h1 { font-size: 34px; line-height: 1.2; margin: 18px 0 16px; }
  @media (max-width: 640px) { .page h1 { font-size: 26px; } }
  .lead { font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 28px; }

  .contact-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-elevated);
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .ch-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    margin-bottom: 4px;
  }

  .ch-value {
    font-size: 17px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .ch-help {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .section { margin-top: 32px; }
  .section h2 { font-size: 22px; margin: 0 0 12px; }
  .text { color: var(--text-secondary); font-size: 16px; line-height: 1.6; margin: 0; }

  .bullet-list { list-style: none; padding: 0; margin: 8px 0 0; }
  .bullet-list li {
    padding-left: 22px;
    position: relative;
    margin-bottom: 10px;
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.55;
  }
  .bullet-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .bullet-list strong { color: var(--text-primary); font-weight: 500; }
</style>
