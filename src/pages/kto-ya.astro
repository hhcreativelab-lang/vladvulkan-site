---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Icon from '@components/Icon.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { personSchema } from '@lib/schema';

const facts = [
  { icon: 'globe', label: 'В Латинской Америке', value: '13 лет' },
  { icon: 'home', label: 'Опыт в недвижимости', value: '8+ лет' },
  { icon: 'chat', label: 'Языки работы', value: 'RU · ES' },
  { icon: 'pin', label: 'Городов работы', value: '5' },
];

const blocks = [
  {
    icon: 'compass',
    title: 'Чем я занимаюсь',
    text: 'Сопровождаю сделки с недвижимостью в Эквадоре для русскоязычной аудитории. Подбираю объекты по всему рынку, проверяю документы и историю, веду переговоры. Юридическое оформление сделки идёт через лицензированного партнёра-корредора. Сейчас я также на пути получения собственной лицензии.',
  },
  {
    icon: 'shield-check',
    title: 'Почему модель «эксперт + партнёр»',
    text: 'Лицензированный риэлтор обычно получает комиссию от продавца. Я работаю напрямую с покупателем — мой гонорар платите только вы. Партнёр-корредор оформляет сделку юридически и подтверждает её чистоту. Так у вас два независимых эксперта на стороне покупки вместо одного с двумя сторонами интересов.',
  },
  {
    icon: 'gem',
    title: 'У меня нет «своей базы объектов»',
    text: 'Я подбираю из всего рынка — частные продажи, базы корредоров, застройщики, аукционы, реверсивные предложения. Это позволяет точнее закрыть вашу задачу, а не продать «то, что есть в портфеле».',
  },
];
---

<BaseLayout
  title="Влад Вулкан — независимый эксперт по недвижимости в Эквадоре"
  description="Влад Вулкан — независимый эксперт по недвижимости в Эквадоре. 13 лет в ЛатАм, 8+ лет в недвижимости, билингв ES/RU. Куэнка, Кито, Гуаякиль."
  jsonLd={personSchema()}
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'О Владе', href: '/kto-ya' }]} />

    <article class="page reveal">
      <span class="eyebrow gold">Об авторе</span>
      <h1>Влад&nbsp;<em>Вулкан</em></h1>
      <p class="lead">
        Независимый эксперт по&nbsp;недвижимости в&nbsp;Эквадоре для&nbsp;русскоязычной аудитории.
        Базируюсь в&nbsp;Куэнке, веду сделки в&nbsp;5&nbsp;городах страны.
      </p>

      <!-- Цифры о себе -->
      <div class="facts-row reveal-stagger">
        {facts.map((f) => (
          <div class="fact frame-bar">
            <div class="fact-icon"><Icon name={f.icon} size={26} stroke={1.25} /></div>
            <div class="fact-value">{f.value}</div>
            <div class="fact-label">{f.label}</div>
          </div>
        ))}
      </div>

      <!-- Блоки -->
      <div class="story reveal-stagger">
        {blocks.map((block) => (
          <div class="story-block frame-bar">
            <div class="story-icon"><Icon name={block.icon} size={32} stroke={1.25} /></div>
            <h2>{block.title}</h2>
            <p>{block.text}</p>
          </div>
        ))}
      </div>

      <!-- Форматы работы -->
      <section class="formats reveal">
        <h2 class="block-title">Три формата работы со&nbsp;мной</h2>
        <div class="formats-grid">
          <div class="format frame-side">
            <div class="format-label">Рядом</div>
            <p>Вы в Эквадоре, осматриваете сами, я даю экспертизу, проверки и переговоры.</p>
          </div>
          <div class="format frame-side">
            <div class="format-label">Гибрид</div>
            <p>Я отбираю кандидатов, вы прилетаете на финальный осмотр и сделку.</p>
          </div>
          <div class="format frame-side">
            <div class="format-label">Удалённо</div>
            <p>Полностью по нотариальной доверенности — от первой консультации до получения ключей.</p>
          </div>
        </div>
      </section>

      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 96px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.035em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }

  .facts-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 40px;
  }
  @media (max-width: 720px) { .facts-row { grid-template-columns: repeat(2, 1fr); } }

  .fact {
    text-align: center;
    padding: 22px 16px;
  }
  .fact-icon {
    color: var(--gold-champagne);
    display: flex;
    justify-content: center;
    margin-bottom: 10px;
  }
  .fact-value {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 28px);
    color: var(--text-light);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }
  .fact-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-mute);
  }

  .story {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-bottom: 60px;
  }
  .story-block {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .story-icon { color: var(--gold-champagne); }
  .story-block h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.6vw, 30px);
    color: var(--text-light);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .story-block p {
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.7;
    margin: 0;
    font-weight: 300;
  }

  .formats { margin-bottom: 60px; }
  .block-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }
  .formats-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .format-label {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--gold-champagne);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .format p {
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
  }
</style>
