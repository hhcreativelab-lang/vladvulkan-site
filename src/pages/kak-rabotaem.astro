---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ComparisonTable from '@components/ComparisonTable.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';

const faqs = [
  {
    question: 'Кто несёт юридическую ответственность за сделку?',
    answer:
      'За юридическое оформление сделки отвечает лицензированный партнёр-корредор. Я отвечаю за качество подбора объектов, due diligence и переговоры — то есть за вашу выгоду в сделке.',
  },
  {
    question: 'Сколько лицензированных партнёров в моей сети?',
    answer:
      'Несколько проверенных корредоров и юристов в Куэнке, Кито, Гуаякиле и на побережье. Под каждую сделку выбирается партнёр с лучшим профилем для конкретной локации и типа объекта.',
  },
  {
    question: 'Партнёр получает комиссию от продавца?',
    answer:
      'Партнёр-корредор получает свой стандартный гонорар за юридическое оформление — это его работа. Моя позиция консультанта на стороне покупателя при этом сохраняется: я не делю комиссию с продавцом или агентствами.',
  },
  {
    question: 'Что если объект на стороне другого корредора?',
    answer:
      'Это нормальная ситуация в Эквадоре — большинство объектов проходят через нескольких корредоров параллельно. Партнёр работает с продавцовой стороной, я — с вашей. Гонорары разделены, конфликта интересов нет.',
  },
  {
    question: 'Можно ли купить недвижимость дистанционно?',
    answer:
      'Да. Через нотариальную доверенность партнёр-корредор подписывает escritura от вашего имени. Регистрация в реестре собственности занимает 7–15 дней. Деньги идут через escrow или прямой банковский перевод с чеком из банка-эмитента.',
  },
];
---

<BaseLayout
  title="Как работает консультант по недвижимости в Эквадоре"
  description="Модель «консультант + лицензированный партнёр-корредор» — как проходит сделка по покупке недвижимости в Эквадоре. Прозрачно и без конфликта интересов."
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'Как работаем', href: '/kak-rabotaem' }]} />

    <article class="page reveal">
      <span class="eyebrow gold">Модель работы</span>
      <h1>Как работает<br>независимый <em>консультант</em><br>по&nbsp;недвижимости</h1>
      <p class="lead">
        Объясняю, почему я не риэлтор, кто такой партнёр-корредор и как делятся роли в&nbsp;сделке.
      </p>

      <div class="prose">
        <h2>Кто такой consultor inmobiliario</h2>
        <p>
          Consultor inmobiliario — это консультант по недвижимости. В Эквадоре эта роль чётко отделена от
          лицензированного риэлтора (corredor de bienes raíces). Консультант не имеет права самостоятельно
          оформлять куплю-продажу — но может проводить независимый анализ, due diligence, переговоры,
          представлять интересы покупателя на любой стадии.
        </p>
        <p>
          Я работаю именно так: моя задача — закрыть вашу инвестиционную или жизненную задачу с минимальным
          риском и максимальной выгодой. Сделку юридически оформляет партнёр-корредор.
        </p>

        <h2>Кто такой партнёр-корредор и что он делает</h2>
        <p>Партнёр-корредор — лицензированный риэлтор-юрист, с которым я работаю по каждой сделке. Его зона ответственности:</p>
        <ul>
          <li>Юридическое оформление escritura (договора купли-продажи у нотариуса)</li>
          <li>Регистрация перехода права в Registro de la Propiedad</li>
          <li>Сопровождение по налогам сделки (alcabala, IPM)</li>
          <li>Доверенности при удалённой схеме</li>
        </ul>

        <h2>Как делятся роли</h2>
        <ComparisonTable
          headers={["Я (consultor inmobiliario)", "Партнёр-корредор"]}
          rows={[
            { label: 'Подбор объекта', cells: ['Из всего рынка, под вашу задачу', 'Не участвует на этом этапе'] },
            { label: 'Due diligence', cells: ['Документы, история, физическое состояние, рыночная цена', 'Юридическая чистота, ipoteca, обременения'] },
            { label: 'Переговоры', cells: ['Веду от вашего имени, сбиваю цену', 'Финализирует условия в escritura'] },
            { label: 'Сделка у нотариуса', cells: ['Сопровождаю, перевожу с испанского, контролирую', 'Подписывает / оформляет / регистрирует'] },
            { label: 'Кто платит', cells: ['Только вы (покупатель)', 'Стандартный гонорар за юридическое оформление'] },
            { label: 'Конфликт интересов', cells: ['Нет — я не работаю с продавцом', 'Нет — он юрист сделки, не агент продавца'] },
          ]}
        />

        <h2>Этапы сделки</h2>
        <ol class="steps">
          <li><strong>Стратегическая консультация ($150, 60&nbsp;мин).</strong> Разбираем бюджет, цели, формат, города.</li>
          <li><strong>Подбор объектов.</strong> Корредоры, частные продажи, застройщики. Short-list 3–7 объектов.</li>
          <li><strong>Due diligence.</strong> Certificado de gravámenes, история, технический осмотр, проверка по налогам.</li>
          <li><strong>Переговоры.</strong> Стандартная скидка от заявленной&nbsp;— 8–18%.</li>
          <li><strong>Подписание у нотариуса.</strong> Escritura de compraventa с участием партнёра-корредора.</li>
          <li><strong>Регистрация и передача ключей.</strong> Внесение в Registro de la Propiedad, оплата alcabala.</li>
        </ol>

        <h2>Чем отличается от работы с обычным риэлтором</h2>
        <ComparisonTable
          headers={["Обычный риэлтор", "Независимый консультант + партнёр"]}
          rows={[
            { label: 'Кто платит', cells: ['Продавец (обычно 3–6% от сделки)', 'Покупатель (вы)'] },
            { label: 'Конфликт интересов', cells: ['Есть — заинтересован продать дороже', 'Нет — заинтересован купить вам выгоднее'] },
            { label: 'База объектов', cells: ['Своя или агентская — ограниченная', 'Весь рынок — корредоры, частные, застройщики'] },
            { label: 'Due diligence', cells: ['Минимальный, агенту проще «не заметить»', 'Полный — это часть моей услуги'] },
            { label: 'Прозрачность гонорара', cells: ['Часто «зашит» в цену', 'Всегда явный, фиксированный или гибридный'] },
          ]}
        />
      </div>

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.5vw, 72px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }
  .steps {
    margin: 18px 0 32px;
    padding-left: 0;
    list-style: none;
    counter-reset: step;
  }
  .steps li {
    counter-increment: step;
    padding: 18px 0 18px 56px;
    position: relative;
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.65;
    border-bottom: 1px solid rgba(157, 127, 255, 0.08);
    font-weight: 300;
  }
  .steps li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gold-champagne);
    letter-spacing: 0.1em;
  }
  .steps strong { color: var(--text-light); display: block; margin-bottom: 4px; font-weight: 500; }
  .steps li:last-child { border-bottom: none; }
</style>
