---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Icon from '@components/Icon.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';

const roles = [
  {
    icon: 'compass',
    title: 'Я — независимый эксперт',
    points: [
      'Подбор объекта по всему рынку под вашу задачу',
      'Due diligence: документы, история, физическое состояние',
      'Переговоры от вашего имени',
      'Сопровождение и контроль всей сделки',
      'Перевод с испанского, общение с банками и нотариусами',
    ],
  },
  {
    icon: 'shield-check',
    title: 'Партнёр-корредор — лицензированный оформитель',
    points: [
      'Юридическое оформление escritura у нотариуса',
      'Регистрация перехода права в Registro de la Propiedad',
      'Сопровождение по налогам сделки (alcabala, IPM)',
      'Доверенности при удалённой схеме',
      'Сейчас я также на пути получения собственной лицензии',
    ],
  },
];

const steps = [
  { num: '01', title: 'Стратегическая консультация', desc: '60 минут, $100. Разбираем бюджет, цели, формат, города.' },
  { num: '02', title: 'Подбор объектов', desc: 'Корредоры, частные продажи, застройщики. Short-list 3–7 объектов.' },
  { num: '03', title: 'Due diligence', desc: 'Certificado de gravámenes, история, технический осмотр, проверка по налогам.' },
  { num: '04', title: 'Переговоры', desc: 'Веду торг от вашего имени, сопровождаю всю коммуникацию.' },
  { num: '05', title: 'Подписание у нотариуса', desc: 'Escritura de compraventa с участием партнёра-корредора. Лично или по доверенности.' },
  { num: '06', title: 'Регистрация и передача ключей', desc: 'Внесение в Registro de la Propiedad, оплата alcabala, акт приёма-передачи.' },
];

const formats = [
  { icon: 'pin', label: 'Рядом', desc: 'Вы в Эквадоре, осматриваете сами, я даю экспертизу и веду переговоры.' },
  { icon: 'globe', label: 'На финал', desc: 'Я отбираю кандидатов, вы прилетаете на финальный осмотр и подписание.' },
  { icon: 'send', label: 'Удалённо', desc: 'Полностью по нотариальной доверенности — от первой консультации до получения ключей.' },
];

const faqs = [
  {
    question: 'Кто несёт юридическую ответственность за сделку?',
    answer:
      'За юридическое оформление сделки отвечает лицензированный партнёр-корредор. Я отвечаю за качество подбора объектов, due diligence и переговоры — за вашу выгоду в сделке. Сейчас я также на пути получения собственной лицензии.',
  },
  {
    question: 'Сколько лицензированных партнёров в сети?',
    answer:
      'Несколько проверенных корредоров и юристов в Куэнке, Кито, Гуаякиле и на побережье. Под каждую сделку выбирается партнёр с лучшим профилем для конкретной локации и типа объекта.',
  },
  {
    question: 'Можно ли купить недвижимость дистанционно?',
    answer:
      'Да. Через нотариальную доверенность партнёр-корредор подписывает escritura от вашего имени. Регистрация в реестре собственности занимает 7–15 дней. Деньги идут через escrow или прямой банковский перевод.',
  },
];
---

<BaseLayout
  title="Как работает независимый эксперт по недвижимости в Эквадоре"
  description="Модель «независимый эксперт + лицензированный партнёр-корредор» — как проходит сделка по покупке недвижимости в Эквадоре. Прозрачно и без посредников."
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'Как работаем', href: '/kak-rabotaem' }]} />

    <article class="page reveal">
      <span class="eyebrow gold">Модель работы</span>
      <h1>Как проходит<br><em>сделка с&nbsp;нуля</em></h1>
      <p class="lead">
        Я веду весь процесс как&nbsp;независимый эксперт, лицензированный партнёр-корредор оформляет
        сделку юридически. Сейчас я&nbsp;также на&nbsp;пути получения собственной лицензии.
      </p>

      <!-- Кто что делает -->
      <section class="roles">
        <h2 class="block-title">Распределение ролей</h2>
        <div class="roles-grid">
          {roles.map((role) => (
            <div class="role-card frame-bar">
              <div class="role-icon"><Icon name={role.icon} size={32} stroke={1.25} /></div>
              <h3>{role.title}</h3>
              <ul>
                {role.points.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Этапы -->
      <section class="steps-section">
        <h2 class="block-title">Шесть этапов сделки</h2>
        <div class="steps">
          {steps.map((step) => (
            <div class="step frame-side">
              <div class="step-num">{step.num}</div>
              <div class="step-body">
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Форматы -->
      <section class="formats-section">
        <h2 class="block-title">Три формата участия</h2>
        <div class="formats-grid">
          {formats.map((f) => (
            <div class="format-card frame-bar">
              <div class="format-icon"><Icon name={f.icon} size={28} stroke={1.25} /></div>
              <div class="format-label">{f.label}</div>
              <div class="format-desc">{f.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.5vw, 72px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 48px;
    font-weight: 300;
  }

  .block-title {
    font-family: var(--font-display);
    font-size: clamp(26px, 3vw, 36px);
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }

  .roles { margin-bottom: 60px; }
  .roles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  @media (max-width: 720px) { .roles-grid { grid-template-columns: 1fr; } }

  .role-card { display: flex; flex-direction: column; gap: 14px; }
  .role-icon { color: var(--gold-champagne); }
  .role-card h3 {
    font-family: var(--font-display);
    font-size: 21px;
    color: var(--text-light);
    margin: 0;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .role-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .role-card li {
    padding-left: 20px;
    position: relative;
    color: var(--text-dim);
    font-size: 14.5px;
    line-height: 1.6;
    font-weight: 300;
  }
  .role-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 10px;
    height: 1px;
    background: var(--gold-champagne);
  }

  .steps-section { margin-bottom: 60px; }
  .steps {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 22px;
  }
  .step-num {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 38px);
    color: var(--gold-champagne);
    line-height: 1;
    letter-spacing: -0.025em;
    min-width: 60px;
  }
  .step-body { flex: 1; }
  .step-body h3 {
    font-family: var(--font-display);
    font-size: 19px;
    color: var(--text-light);
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    font-weight: 400;
  }
  .step-body p {
    color: var(--text-dim);
    font-size: 14.5px;
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
  }

  .formats-section { margin-bottom: 40px; }
  .formats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 720px) { .formats-grid { grid-template-columns: 1fr; } }
  .format-card {
    text-align: center;
    padding: clamp(28px, 3vw, 36px) 22px;
  }
  .format-icon {
    color: var(--gold-champagne);
    display: flex;
    justify-content: center;
    margin-bottom: 14px;
  }
  .format-label {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--text-light);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .format-desc {
    color: var(--text-dim);
    font-size: 13.5px;
    line-height: 1.55;
    font-weight: 300;
  }
</style>
