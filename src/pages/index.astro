  .city-summary-text {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 300;
  }
  .city-toggle {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(229, 198, 120, 0.08);
    color: var(--gold-champagne);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(229, 198, 120, 0.25);
