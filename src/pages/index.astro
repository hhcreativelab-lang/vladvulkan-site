---
import BaseLayout from '@layouts/BaseLayout.astro';
import CategoryCard from '@components/CategoryCard.astro';
import FAQBlock from '@components/FAQBlock.astro';
import Icon from '@components/Icon.astro';
import EcuadorMap from '@components/EcuadorMap.astro';
import { SITE, CATEGORIES } from '@lib/constants';
import { professionalServiceSchema, faqPageSchema } from '@lib/schema';

const homeFaqs = [
  {
    question: 'Как устроена работа со сделкой?',
    answer:
      'Я сопровождаю клиента как независимый эксперт. Юридическое оформление сделки идёт через лицензированного партнёра-корредора. Сейчас я также на пути получения собственной лицензии. Такая модель даёт два независимых эксперта на стороне покупателя.',
  },
  {
    question: 'Какой у вас опыт?',
    answer:
      '13 лет жизни в Латинской Америке и 8+ лет работы в недвижимости Эквадора. Знаю рынки Куэнки, Кито, Гуаякиля, побережья — на уровне реальных сделок, не теории. Билингв (испанский + русский), работаю напрямую с местными нотариусами и банками.',
  },
  {
    question: 'Как проходит сделка?',
    answer:
      'Стратегическая консультация → подбор объектов по всему рынку → due diligence документов → переговоры → подписание у нотариуса → передача ключей. Я веду весь процесс, партнёр обеспечивает юридическое оформление.',
  },
  {
    question: 'Сколько это стоит?',
    answer:
      'Стратегическая консультация — $100 за 60 минут, засчитывается в пакет. Проверка объекта — $1000 фикс. Сопровождение сделки — от $3000 фикс-пакет (бюджет до $120K) или гибридная модель от $120K.',
  },
  {
    question: 'Вы работаете удалённо?',
    answer:
      'Да. Три формата: вы в Эквадоре сами осматриваете объекты; гибридный — я отбираю кандидатов, вы прилетаете на финал; полностью удалённый — я работаю за вас по нотариальной доверенности.',
  },
];

const heroCities = [
  { name: 'Куэнка', active: true },
  { name: 'Кито', active: false },
  { name: 'Гуаякиль', active: false },
  { name: 'Манта', active: false },
  { name: 'Салинас', active: false },
];

const facts = [
  { icon: 'users', label: 'Население Эквадора', value: '18 млн', meta: 'По стране' },
  { icon: 'dollar', label: 'Национальная валюта', value: 'USD', meta: 'С 2000 года' },
  { icon: 'home', label: 'Экспаты в Куэнке', value: '8 000+', meta: 'Иностранные резиденты' },
  { icon: 'chat', label: 'Русскоязычная диаспора', value: '3–4 тыс.', meta: 'По всем городам' },
] as const;

const cities = [
  {
    name: 'Куэнка',
    sub: 'Cuenca · Azuay',
    icon: 'building',
    summary: 'Колониальный центр на 2500м, мягкий климат, безопасность.',
    detail: 'Топ для жизни и долгосрочной аренды. Цены на квартиру в центре от $80–120K. ЮНЕСКО, экспат-комьюнити 8000+, медицина мирового уровня. Русскоязычная диаспора 1500+.',
  },
  {
    name: 'Кито',
    sub: 'Quito · Pichincha',
    icon: 'building',
    summary: 'Столица, 2850м, бизнес-центр и дипломатические миссии.',
    detail: 'Подходит для бизнеса и работы с госорганами. Премиум-сегмент в Cumbayá и La Carolina. Цены м² от $1500. Аэропорт-хаб для всей страны.',
  },
  {
    name: 'Гуаякиль',
    sub: 'Guayaquil · Guayas',
    icon: 'building',
    summary: 'Порт, экономическая столица. Жара и влажность.',
    detail: 'Сильный сегмент элитной недвижимости в Samborondón — закрытые комьюнити, высокий стандарт. Бизнес-центр страны, главный порт. Цены премиум-сегмента $200–600K.',
  },
  {
    name: 'Манта',
    sub: 'Manta · Manabí',
    icon: 'beach',
    summary: 'Развивающийся курорт + порт. Доступные цены.',
    detail: 'Океан, развитая инфраструктура, ниже цен Салинаса. Высокий потенциал роста при инфраструктурных проектах. Квартира с видом на океан от $90K.',
  },
  {
    name: 'Салинас',
    sub: 'Salinas · Santa Elena',
    icon: 'beach',
    summary: 'Тихоокеанское побережье, премиум-сегмент.',
    detail: 'Главный курорт Эквадора. Краткосрочная аренда даёт высокую доходность 8–12% годовых. Премиум-апартаменты на побережье от $150K.',
  },
];

const examples = [
  {
    icon: 'home',
    title: 'Квартира в Куэнке для аренды',
    price: '$85–120K',
    note: 'Доходность 6–8% годовых',
    detail: '2-3 комнаты, центр или Río Tomebamba. Стабильный спрос экспатов. Низкие коммунальные расходы (~$50/мес).',
  },
  {
    icon: 'beach',
    title: 'Дом в Салинас для семьи',
    price: '$180–250K',
    note: 'Океан в 5 минутах',
    detail: '3-4 спальни, закрытое комьюнити с охраной. Бассейн, паркинг. Подходит для постоянного проживания или сезонной аренды.',
  },
  {
    icon: 'building',
    title: 'Премиум-пентхаус в Кито',
    price: '$350K+',
    note: 'Центр, вид на Анды',
    detail: 'La Carolina или Cumbayá. 4 спальни, терраса 80м². Закрытый комплекс с консьержем, спа, паркингом. Прямой выход к рынку премиум-аренды.',
  },
];

const schemas = [
  professionalServiceSchema(),
  faqPageSchema(homeFaqs)!,
];
---

<BaseLayout
  title="Независимая экспертиза по недвижимости в Эквадоре"
  description="Влад Вулкан — сопровождаю сделки с недвижимостью в Эквадоре для русскоязычной аудитории. 8+ лет опыта, 5 городов: Куэнка, Кито, Гуаякиль, Манта, Салинас."
  jsonLd={schemas}
  headerVariant="overlay"
>
  <!-- ============== HERO ============== -->
  <section class="hero">
    <div class="hero-photo" aria-hidden="true">
      <picture>
        <source type="image/avif" srcset="/assets/vlad-hero.avif" />
        <source type="image/jpeg" srcset="/assets/vlad-hero-1920.jpg 1920w, /assets/vlad-hero-2560.jpg 2560w" sizes="100vw" />
        <img src="/assets/vlad-hero-1920.jpg" alt="" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
      <div class="hero-photo-overlay"></div>
    </div>
    <div class="hero-mesh" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-grid container">
      <div class="hero-spacer" aria-hidden="true"></div>
      <div class="hero-text">
        <span class="hero-eyebrow eyebrow-line">Независимый эксперт · Куэнка, Эквадор</span>

        <h1 class="hero-title">
          <span>Недвижимость</span>
          <span>в&nbsp;<em>Эквадоре</em></span>
          <span class="hero-tagline">с экспертом, который на&nbsp;вашей стороне</span>
        </h1>

        <div class="cities">
          {heroCities.map((city, i) => (
            <>
              {i > 0 && <span class="city-sep">·</span>}
              <span class:list={["city", { active: city.active }]}>
                <span class="city-dot"></span>{city.name}
              </span>
            </>
          ))}
        </div>

        <div class="hero-sub-wrap">
          <p class="hero-sub">
            Я — Влад&nbsp;Вулкан. Сопровождаю сделки с&nbsp;недвижимостью в&nbsp;Эквадоре для&nbsp;русскоязычной аудитории.
            13&nbsp;лет в&nbsp;Латинской Америке, 8+&nbsp;лет в&nbsp;недвижимости. Работаю на&nbsp;<em>стороне клиента</em>.
          </p>
        </div>

        <div class="hero-actions">
          <a href={SITE.telegramUrl} class="btn-quiz" rel="noopener">
            <span class="btn-quiz-main">
              Свяжитесь <em>со&nbsp;мной</em>
            </span>
            <span class="btn-quiz-divider"></span>
            <span class="btn-quiz-meta">Ответ за 24 ч</span>
          </a>

          <div class="social">
            <a href={SITE.telegramUrl} class="soc-link tg" rel="noopener">
              <span class="soc-dot"></span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.05 2.434 2.42 9.9c-1.34.525-1.33 1.276-.242 1.606l5.05 1.577 11.688-7.372c.553-.334 1.057-.155.641.213L9.117 14.47l-.363 5.439c.523 0 .753-.24 1.046-.524l2.507-2.422 5.21 3.833c.96.528 1.65.256 1.889-.89l3.418-16.081c.349-1.405-.54-2.044-1.772-1.39"/></svg>
              Telegram
            </a>
            <a href={SITE.youtubeUrl} class="soc-link yt" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8M9.6 15.6V8.4l6.2 3.6z"/></svg>
              YouTube
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="clock-bar container">
      <div class="clocks">
        <div class="clock active"><span class="clock-dot"></span><span class="clock-name">Куэнка</span><span class="clock-time" id="t-cuenca">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Москва</span><span class="clock-time" id="t-moscow">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Киев</span><span class="clock-time" id="t-kyiv">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Берлин</span><span class="clock-time" id="t-berlin">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Нью-Йорк</span><span class="clock-time" id="t-ny">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Торонто</span><span class="clock-time" id="t-toronto">—:—</span></div>
      </div>
    </div>
  </section>

  <!-- ============== FACTS — 6 плашек ============== -->
  <section class="facts-section noise">
    <div class="container">
      <div class="facts-head reveal">
        <span class="eyebrow gold">Эквадор в цифрах</span>
        <h2>Четыре факта,<br>которые <em>важно знать</em></h2>
      </div>

      <div class="facts-grid reveal-stagger">
        {facts.map((f) => (
          <div class="fact-tile">
            <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-br"></span>
            <div class="fact-icon"><Icon name={f.icon} size={32} stroke={1.25} /></div>
            <div class="fact-label">{f.label}</div>
            <div class="fact-value">{f.value}</div>
            <div class="fact-meta">{f.meta}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== 3D КАРТА ЭКВАДОРА ============== -->
  <section class="map-section noise">
    <div class="container">
      <div class="map-section-head reveal">
        <span class="eyebrow gold">География</span>
        <h2>Эквадор<br><em>в&nbsp;четырёх измерениях</em></h2>
        <p>Четыре природных региона, пять городов работы. Наведите на&nbsp;регион&nbsp;— увидите подробности.</p>
      </div>
      <div class="map-section-body reveal">
        <EcuadorMap />
      </div>
    </div>
  </section>

  <!-- ============== USLUGI — 4 ФОРМЫ ============== -->
  <section class="services-section">
    <div class="container">
      <div class="services-head reveal">
        <span class="eyebrow gold">Четыре формы работы</span>
        <h2>От&nbsp;консультации<br><em>до&nbsp;сделки и&nbsp;инвестиций</em></h2>
        <p>Подберите формат под&nbsp;свою задачу. Юридическое оформление сделки идёт через лицензированного партнёра-корредора.</p>
      </div>

      <div class="services-grid four-cols reveal-stagger">
        <a href="/uslugi/konsultatsiya" class="service-card pillar pillar-2c">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-br"></span>
          <div class="srv-eyebrow">Первый шаг</div>
          <h3>Стратегическая консультация</h3>
          <p>60 минут разбираем ситуацию: бюджет, цели, города и&nbsp;форматы. Засчитывается в&nbsp;пакет.</p>
          <div class="srv-bottom"><span class="srv-price">$100 · 60 мин</span><span class="srv-arrow">→</span></div>
        </a>
        <a href="/uslugi/proverka-objekta" class="service-card pillar pillar-2c">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-br"></span>
          <div class="srv-eyebrow">Только проверка</div>
          <h3>Проверка объекта</h3>
          <p>Вы нашли объект сами. Я делаю due diligence, проверяю цену против рынка, веду торг.</p>
          <div class="srv-bottom"><span class="srv-price">$1000 фикс</span><span class="srv-arrow">→</span></div>
        </a>
        <a href="/uslugi/soprovozhdenie-sdelki" class="service-card pillar pillar-2c">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-br"></span>
          <div class="srv-eyebrow">Полный пакет</div>
          <h3>Сопровождение сделки</h3>
          <p>Подбор объекта по&nbsp;всему рынку, due diligence, переговоры, сопровождение у&nbsp;нотариуса.</p>
          <div class="srv-bottom"><span class="srv-price">От $3000 / гибрид</span><span class="srv-arrow">→</span></div>
        </a>
        <a href={SITE.telegramUrl} class="service-card pillar pillar-2c" rel="noopener">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-br"></span>
          <div class="srv-eyebrow">Индивидуально</div>
          <h3>Инвестиционные возможности</h3>
          <p>Есть идея, проект, объект или интерес к&nbsp;инвестициям в&nbsp;Эквадоре? Напишите в&nbsp;Telegram&nbsp;— рассмотрим и&nbsp;ответим.</p>
          <div class="srv-bottom"><span class="srv-price">По запросу</span><span class="srv-arrow">→</span></div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============== ГОРОДА — раскрывающиеся ============== -->
  <section class="cities-section noise">
    <div class="container">
      <div class="cities-head reveal">
        <span class="eyebrow gold">География работы</span>
        <h2>Пять <em>направлений</em>,<br>где я веду сделки</h2>
        <p>Куэнка, Кито, Гуаякиль, Манта, Салинас. Откройте город&nbsp;— узнайте детали по&nbsp;сегменту, ценам и&nbsp;климату.</p>
      </div>

      <div class="cities-list reveal">
        {cities.map((city, i) => (
          <details class="city-item" open={i === 0}>
            <summary>
              <div class="city-summary">
                <div class="city-icon"><Icon name={city.icon} size={26} stroke={1.25} /></div>
                <div class="city-text">
                  <div class="city-name">{city.name}</div>
                  <div class="city-sub-name">{city.sub}</div>
                </div>
                <div class="city-summary-text">{city.summary}</div>
                <div class="city-toggle" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 5v14M5 12h14"/>
                  </svg>
                </div>
              </div>
            </summary>
            <div class="city-detail">
              <p>{city.detail}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== ПРИМЕРЫ ОБЪЕКТОВ ============== -->
  <section class="examples-section">
    <div class="container">
      <div class="examples-head reveal">
        <span class="eyebrow gold">Что доступно</span>
        <h2>Реальные сегменты,<br>с&nbsp;<em>конкретными ценами</em></h2>
        <p>Три типичных запроса, на&nbsp;которые приходит русскоязычный клиент. Цены — медиана 2026&nbsp;года.</p>
      </div>

      <div class="examples-grid reveal-stagger">
        {examples.map((ex) => (
          <div class="example-card pillar pillar-2c">
            <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-br"></span>
            <div class="ex-icon"><Icon name={ex.icon} size={32} stroke={1.25} /></div>
            <h3>{ex.title}</h3>
            <div class="ex-price">{ex.price}</div>
            <div class="ex-note">{ex.note}</div>
            <div class="ex-detail">{ex.detail}</div>
          </div>
        ))}
      </div>

      <div class="examples-foot reveal">
        <a href="/tseny" class="btn btn-gold">Калькулятор сделки</a>
      </div>
    </div>
  </section>

  <!-- ============== КАТАЛОГ ============== -->
  <section class="catalog-section noise">
    <div class="container">
      <div class="cat-head reveal">
        <span class="eyebrow gold">Каталог знаний</span>
        <h2>Всё про&nbsp;Эквадор<br>для&nbsp;<em>русскоязычных</em></h2>
        <p>Семь категорий: деньги, недвижимость, безопасность, ВНЖ, жизнь, сравнения, бизнес.</p>
      </div>
      <div class="cat-grid reveal-stagger">
        {Object.values(CATEGORIES).map((cat) => (
          <CategoryCard slug={cat.slug} name={cat.name} description={cat.description} />
        ))}
      </div>
      <div class="cat-foot reveal">
        <a href="/znaniya" class="btn btn-gold">Открыть каталог</a>
      </div>
    </div>
  </section>

  <!-- ============== FAQ ============== -->
  <div class="container-narrow">
    <FAQBlock faqs={homeFaqs} skipSchema title="Частые вопросы" />
  </div>

  <!-- ============== ФИНАЛЬНЫЙ CTA ============== -->
  <section class="final-cta">
    <div class="final-bg" aria-hidden="true"></div>
    <div class="final-glow" aria-hidden="true"></div>
    <div class="container final-inner">
      <span class="eyebrow gold">Следующий шаг</span>
      <h2>Готов начать разговор<br>про&nbsp;<em>недвижимость</em> в&nbsp;Эквадоре?</h2>
      <p>Пройдите квиз за&nbsp;2&nbsp;минуты&nbsp;— я&nbsp;пойму вашу задачу и&nbsp;подготовлю короткий разбор. Без&nbsp;спама, без&nbsp;звонков.</p>

      <div class="final-actions">
        <a href={SITE.telegramUrl} class="btn-quiz" rel="noopener">
          <span class="btn-quiz-main">
            Пройти <em>квиз</em>
          </span>
          <span class="btn-quiz-divider"></span>
          <span class="btn-quiz-meta">2 минуты</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============== HERO ============== */
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
    background: var(--void);
  }

  .hero-photo { position: absolute; inset: 0; z-index: 1; }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 22% 35%;
    filter: contrast(1.05) saturate(0.92) brightness(0.7);
    animation: heroKenBurns 35s ease-in-out infinite alternate;
  }
  .hero-photo-overlay {
    position: absolute;
    inset: 0;
    background:
      /* Затемнение справа под текст. Слева — Влад открыт. */
      linear-gradient(90deg, transparent 0%, rgba(7, 3, 16, 0.05) 35%, rgba(7, 3, 16, 0.45) 55%, rgba(7, 3, 16, 0.78) 78%, rgba(7, 3, 16, 0.88) 100%),
      /* Снизу переход в void */
      linear-gradient(180deg, transparent 0%, transparent 60%, rgba(7, 3, 16, 0.5) 85%, var(--void) 100%),
      /* Тонировка фиолет */
      linear-gradient(225deg, rgba(76, 29, 149, 0.22) 0%, transparent 55%);
  }
  picture { display: contents; }
  @keyframes heroKenBurns {
    0% { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.08) translate(-1%, -1%); }
  }

  .hero-mesh {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse 800px 600px at 75% 40%, rgba(157, 127, 255, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse 600px 500px at 20% 80%, rgba(212, 175, 55, 0.06) 0%, transparent 50%);
    background-size: 150% 150%, 150% 150%;
    animation: heroMesh 30s ease-in-out infinite alternate;
    mix-blend-mode: screen;
    pointer-events: none;
  }
  @keyframes heroMesh {
    0% { background-position: 0% 0%, 0% 0%; }
    100% { background-position: 100% 100%, 50% 50%; }
  }

  .hero-glow {
    position: absolute;
    bottom: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--violet-bright), transparent);
    box-shadow: 0 0 24px var(--violet-glow);
    z-index: 5;
  }

  .hero-grid {
    position: relative;
    z-index: 10;
    flex: 1;
    display: grid;
    /* левая колонка пустая (фото), правая — фиксированная под текст */
    grid-template-columns: minmax(0, 1fr) minmax(0, clamp(380px, 45vw, 620px));
    gap: clamp(20px, 4vw, 60px);
    align-items: center;
    padding-top: clamp(110px, 16vh, 180px);
    padding-bottom: clamp(40px, 6vw, 80px);
  }

  .hero-spacer { /* Левая колонка — фото проступает */ min-width: 0; }

  .hero-text {
    min-width: 0;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 2.2vw, 32px);
    text-align: left;
  }

  .hero-eyebrow {
    color: var(--gold-champagne);
    text-shadow: 0 1px 8px rgba(7, 3, 16, 0.85);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.2vw, 76px);
    line-height: 0.96;
    font-weight: 400;
    letter-spacing: -0.035em;
    color: var(--text-light);
    margin: 0;
    text-shadow:
      0 0 48px rgba(7, 3, 16, 0.95),
      0 4px 24px rgba(7, 3, 16, 0.85),
      0 2px 8px rgba(7, 3, 16, 0.7);
  }
  .hero-title span { display: block; }
  /* Все слова — БЕЛЫЕ. Курсив без градиента. */
  .hero-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--text-light);
    background: none;
    -webkit-text-fill-color: var(--text-light);
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(15px, 1.4vw, 21px) !important;
    color: var(--ivory-dim) !important;
    font-style: italic;
    margin-top: 12px !important;
    font-weight: 300 !important;
    letter-spacing: -0.005em;
    line-height: 1.3 !important;
  }

  /* Cities в hero */
  .cities {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-mute);
    flex-wrap: wrap;
    text-shadow: 0 1px 6px rgba(7, 3, 16, 0.75);
  }
  .city {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: color 0.4s;
  }
  .city-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--text-soft);
  }
  .city.active { color: var(--text-light); }
  .city.active .city-dot {
    background: var(--green);
    box-shadow: 0 0 10px rgba(74, 222, 128, 0.6);
  }
  .city-sep { color: var(--text-soft); opacity: 0.5; }

  .hero-sub-wrap {
    position: relative;
    padding-left: 22px;
  }
  .hero-sub-wrap::before {
    content: '';
    position: absolute;
    top: 6px; bottom: 6px; left: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--violet-bright), transparent);
    border-radius: 2px;
  }
  .hero-sub {
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.7;
    color: var(--text-light);
    font-weight: 300;
    margin: 0;
    text-shadow: 0 1px 8px rgba(7, 3, 16, 0.85);
  }
  .hero-sub em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--text-light);
    background: none;
    -webkit-text-fill-color: var(--text-light);
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .social {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .soc-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    background: rgba(16, 8, 34, 0.6);
    border: 1px solid rgba(157, 127, 255, 0.18);
    border-radius: 2px;
    color: var(--text-dim);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
    transition: border-color 0.6s var(--ease-premium), box-shadow 0.6s var(--ease-premium), background 0.6s var(--ease-premium), color 0.4s;
  }
  .soc-link.tg:hover {
    border-color: var(--tg-blue);
    background: rgba(42, 171, 238, 0.08);
    color: var(--text-light);
    box-shadow: 0 0 0 1px rgba(42, 171, 238, 0.4), 0 0 20px rgba(42, 171, 238, 0.25);
  }
  .soc-link.tg:hover svg { color: var(--tg-blue); }
  .soc-link.yt:hover {
    border-color: var(--yt-red);
    background: rgba(255, 0, 51, 0.06);
    color: var(--text-light);
    box-shadow: 0 0 0 1px rgba(255, 0, 51, 0.4), 0 0 20px rgba(255, 0, 51, 0.25);
  }
  .soc-link.yt:hover svg { color: var(--yt-red); }
  .soc-link svg { width: 15px; height: 15px; opacity: 0.85; transition: color 0.4s, opacity 0.4s; }
  .soc-link:hover svg { opacity: 1; }
  .soc-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.5);
    animation: pulse 2s ease-in-out infinite;
  }

  /* CLOCK BAR — внизу hero */
  .clock-bar {
    position: relative;
    z-index: 6;
    padding-bottom: 28px;
    padding-top: 12px;
    display: flex;
    justify-content: center;
  }
  .clocks {
    display: flex;
    align-items: center;
    gap: clamp(18px, 2.4vw, 38px);
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
  }
  .clock {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--text-mute);
    transition: color 0.4s;
    text-shadow: 0 1px 6px rgba(7, 3, 16, 0.85);
  }
  .clock.active { color: var(--text-light); }
  .clock-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--text-soft);
  }
  .clock.active .clock-dot {
    background: var(--green);
    box-shadow: 0 0 10px rgba(74, 222, 128, 0.6);
    animation: pulse 2s ease-in-out infinite;
  }
  .clock-name { font-weight: 500; color: var(--violet-bright); }
  .clock-time { color: var(--ivory); font-weight: 600; margin-left: 3px; letter-spacing: 0.04em; }
  .clock.active .clock-time { color: var(--text-light); font-weight: 700; }

  /* Split CTA */
  .btn-quiz {
    display: inline-flex;
    align-items: stretch;
    background: linear-gradient(135deg, #3D2288 0%, #271458 50%, #1A0F47 100%);
    border: 1px solid rgba(157, 127, 255, 0.3);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.6s var(--ease-premium), box-shadow 0.6s var(--ease-premium), transform 0.5s var(--ease-premium);
    box-shadow:
      0 8px 24px rgba(26, 15, 71, 0.5),
      0 2px 8px rgba(61, 34, 136, 0.35),
      inset 0 1px 0 rgba(157, 127, 255, 0.2);
    position: relative;
  }
  .btn-quiz:hover {
    transform: translateY(-2px);
    border-color: rgba(157, 127, 255, 0.55);
    box-shadow:
      0 0 0 1px rgba(157, 127, 255, 0.4),
      0 12px 32px rgba(26, 15, 71, 0.6),
      0 0 40px rgba(106, 61, 232, 0.35),
      inset 0 1px 0 rgba(157, 127, 255, 0.3);
  }
  .btn-quiz-main, .btn-quiz-meta {
    display: inline-flex;
    align-items: center;
    color: var(--text-light);
    white-space: nowrap;
  }
  .btn-quiz-main {
    padding: 20px 28px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    gap: 12px;
  }
  .btn-quiz-main em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ivory);
    background: none;
    -webkit-text-fill-color: var(--ivory);
  }
  .btn-quiz-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, rgba(157, 127, 255, 0.3) 50%, transparent 100%);
    margin: 10px 0;
  }
  .btn-quiz-meta {
    padding: 20px 26px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ivory-dim);
  }

  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; padding-top: 130px; }
    .hero-photo img { object-position: 30% 35%; filter: contrast(1.05) saturate(0.92) brightness(0.5); }
    .hero-photo-overlay {
      background:
        linear-gradient(180deg, rgba(7, 3, 16, 0.5) 0%, rgba(7, 3, 16, 0.7) 100%);
    }
  }

  /* ============== FACTS SECTION ============== */
  .facts-section {
    position: relative;
    background: #050307;
    padding: clamp(80px, 10vw, 140px) 0;
    overflow: hidden;
  }
  .facts-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 1200px 900px at 20% 30%, rgba(157, 127, 255, 0.05) 0%, transparent 50%),
      radial-gradient(ellipse 800px 600px at 80% 70%, rgba(212, 175, 55, 0.025) 0%, transparent 50%);
    background-size: 200% 200%;
    animation: heroMesh 25s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }
  .facts-head {
    text-align: left;
    margin-bottom: clamp(48px, 6vw, 72px);
    max-width: 800px;
    position: relative;
    z-index: 2;
  }
  .facts-head .eyebrow { display: block; margin-bottom: 14px; }
  .facts-head h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    margin: 0 0 18px;
    letter-spacing: -0.025em;
    line-height: 1;
  }
  .facts-head em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .facts-head p {
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.65;
    margin: 0;
    font-weight: 300;
    max-width: 640px;
  }

  .facts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    position: relative;
    z-index: 2;
  }
  @media (max-width: 1100px) { .facts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .facts-grid { grid-template-columns: 1fr; } }

  .fact-tile {
    position: relative;
    background: linear-gradient(180deg, rgba(22, 20, 26, 0.7) 0%, rgba(16, 14, 20, 0.85) 100%);
    border: 1px solid rgba(157, 127, 255, 0.1);
    border-radius: 8px;
    padding: 28px 24px 24px;
    backdrop-filter: blur(8px);
    transition: border-color 0.6s var(--ease-premium), transform 0.5s var(--ease-premium), box-shadow 0.6s var(--ease-premium);
    overflow: hidden;
    min-height: 200px;
    display: flex;
    flex-direction: column;
  }
  .fact-tile:hover {
    border-color: rgba(229, 198, 120, 0.3);
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(229, 198, 120, 0.15),
      0 0 30px rgba(229, 198, 120, 0.1);
  }
  .fact-icon {
    color: var(--violet-bright);
    margin-bottom: 16px;
  }
  .fact-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-champagne);
    margin-bottom: 10px;
  }
  .fact-value {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 400;
    color: var(--text-light);
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 8px;
  }
  .fact-meta {
    font-size: 12.5px;
    color: var(--text-dim);
    font-weight: 300;
    margin-top: auto;
  }

  /* ============== MAP SECTION ============== */
  .map-section {
    position: relative;
    background: var(--midnight);
    padding: clamp(80px, 10vw, 140px) 0;
    overflow: hidden;
  }
  .map-section-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(36px, 5vw, 56px);
  }
  .map-section-head .eyebrow { display: block; margin-bottom: 14px; }
  .map-section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    margin: 0 0 18px;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .map-section-head h2 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .map-section-head p {
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
  }
  .map-section-body {
    max-width: 980px;
    margin: 0 auto;
  }

  /* ============== SERVICES SECTION ============== */
  .services-section {
    padding: clamp(80px, 10vw, 140px) 0;
    background: var(--midnight);
  }
  .services-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(48px, 6vw, 72px);
  }
  .services-head .eyebrow { display: block; margin-bottom: 14px; }
  .services-head h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    margin: 0 0 18px;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .services-head h2 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .services-head p {
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2.5vw, 36px);
  }
  .services-grid.four-cols {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 1100px) {
    .services-grid.four-cols { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .services-grid, .services-grid.four-cols { grid-template-columns: 1fr; }
  }
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    padding: clamp(28px, 3vw, 36px);
    align-items: stretch;
  }
  .srv-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    color: var(--text-light);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .service-card p {
    color: var(--text-dim);
    font-size: 14.5px;
    line-height: 1.65;
    margin: 0;
    flex: 1;
    font-weight: 300;
  }
  .srv-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
    padding-top: 14px;
    border-top: 1px solid rgba(157, 127, 255, 0.1);
  }
  .srv-price {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ivory);
  }
  .srv-arrow {
    color: var(--violet-bright);
    font-size: 20px;
    transition: transform 0.4s var(--ease-premium);
  }
  .service-card:hover .srv-arrow { transform: translateX(4px); }

  /* ============== CITIES SECTION ============== */
  .cities-section {
    padding: clamp(80px, 10vw, 140px) 0;
    background: #050307;
    position: relative;
  }
  .cities-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(48px, 6vw, 72px);
  }
  .cities-head .eyebrow { display: block; margin-bottom: 14px; }
  .cities-head h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    margin: 0 0 18px;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .cities-head em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .cities-head p {
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.65;
    margin: 0;
    font-weight: 300;
  }

  .cities-list {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .city-item {
    background: linear-gradient(180deg, rgba(22, 20, 26, 0.7) 0%, rgba(16, 14, 20, 0.82) 100%);
    border: 1px solid rgba(157, 127, 255, 0.1);
    border-radius: 8px;
    transition: border-color 0.4s var(--ease-premium);
