  .city-text { display: flex; flex-direction: column; gap: 2px; }
  .city-name {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--text-light);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .city-sub-name {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-mute);
