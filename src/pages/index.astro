---
import BaseLayout from '@layouts/BaseLayout.astro';
import CategoryCard from '@components/CategoryCard.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import { SITE, CATEGORIES } from '@lib/constants';
import { professionalServiceSchema, faqPageSchema } from '@lib/schema';

const homeFaqs = [
  {
    question: 'Вы риэлтор?',
    answer:
      'Нет. Я consultor inmobiliario — независимый консультант. Лицензированный партнёр-корредор участвует в сделке как юридический оформитель. Это даёт вам двух независимых экспертов вместо одного, у которого конфликт интересов с продавцом.',
  },
  {
    question: 'Почему у вас нет лицензии риэлтора?',
    answer:
      'Я сознательно работаю как consultor inmobiliario. Лицензированный риэлтор получает комиссию от продавца — это создаёт конфликт интересов. Мой гонорар платите вы — поэтому я работаю только на вашей стороне. Юридическую часть сделки оформляет лицензированный партнёр.',
  },
  {
    question: 'Как проходит сделка?',
    answer:
      'Стратегическая консультация → подбор объектов → проверка документов → переговоры → подписание у нотариуса с участием партнёра-корредора → передача ключей. Я веду весь процесс, партнёр обеспечивает юридическое оформление.',
  },
  {
    question: 'Сколько это стоит?',
    answer:
      'До бюджета $120K — фикс-пакет от $3000. От $120K — гибридная модель: ретейнер при подписании + процент от цены сделки + минимальный гонорар. Полный расчёт под вашу ситуацию — в калькуляторе на странице цен.',
  },
  {
    question: 'Вы работаете удалённо?',
    answer:
      'Да. Три формата: вы в Эквадоре сами осматриваете объекты, я даю экспертную оценку; гибридный — я отбираю кандидатов, вы прилетаете на финал; полностью удалённый — я работаю за вас по нотариальной доверенности.',
  },
];

const cities = [
  { name: 'Куэнка', active: true },
  { name: 'Кито', active: false },
  { name: 'Гуаякиль', active: false },
  { name: 'Манта', active: false },
  { name: 'Салинас', active: false },
];

const services = [
  {
    href: '/uslugi/soprovozhdenie-sdelki',
    eyebrow: 'Полный пакет',
    title: 'Сопровождение сделки',
    text: 'Подбор объекта по всему рынку, due diligence, переговоры, сопровождение у нотариуса.',
    price: 'От $3000 / гибрид',
  },
  {
    href: '/uslugi/konsultatsiya',
    eyebrow: 'Первый шаг',
    title: 'Стратегическая консультация',
    text: '60 минут разбираем вашу ситуацию: бюджет, цели, города и форматы. Засчитывается в пакет.',
    price: '$150 · 60 мин',
  },
  {
    href: '/uslugi/proverka-objekta',
    eyebrow: 'Только проверка',
    title: 'Проверка объекта',
    text: 'Вы нашли объект сами. Я делаю due diligence, проверяю цену против рынка, веду торг.',
    price: '$1500 фикс',
  },
];

const schemas = [
  professionalServiceSchema(),
  faqPageSchema(homeFaqs)!,
];
---

<BaseLayout
  title="Независимая консультация по недвижимости в Эквадоре"
  description="Consultor inmobiliario для русскоязычных. 8+ лет опыта в недвижимости Эквадора. Куэнка, Кито, Гуаякиль, Салинас, Манта. Независимая экспертиза, не риэлтор."
  jsonLd={schemas}
  headerVariant="overlay"
>
  <!-- ============== HERO ============== -->
  <section class="hero">
    <div class="hero-photo" aria-hidden="true">
      <img src="/assets/vlad-hero.jpg" alt="" loading="eager" decoding="async" />
      <div class="hero-photo-overlay"></div>
    </div>
    <div class="hero-mesh" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="hero-content container">
      <div class="hero-eyebrow eyebrow-line">Consultor Inmobiliario · Cuenca, Ecuador</div>

      <h1 class="hero-title">
        <span>Недвижимость</span>
        <span class="line-2">в&nbsp;<em>Эквадоре</em></span>
        <span class="line-3 italic-serif">с экспертом, который на вашей стороне</span>
      </h1>

      <div class="cities">
        <div class="cities-line"></div>
        {cities.map((city, i) => (
          <>
            {i > 0 && <span class="city-sep">·</span>}
            <span class:list={["city", { active: city.active }]}>
              <span class="city-dot"></span>{city.name}
            </span>
          </>
        ))}
        <div class="cities-line"></div>
      </div>

      <div class="hero-sub-wrap">
        <p class="hero-sub">
          Я — Влад&nbsp;Вулкан, consultor inmobiliario для&nbsp;русскоязычной аудитории. 13&nbsp;лет в&nbsp;Латинской Америке,
          8+&nbsp;лет в&nbsp;недвижимости. Работаю на&nbsp;<em>стороне клиента</em>&nbsp;— не&nbsp;получаю комиссию от&nbsp;продавца.
        </p>
      </div>

      <div class="hero-actions">
        <a href={SITE.telegramUrl} class="btn-quiz" rel="noopener">
          <span class="btn-quiz-main">
            Получить <em>консультацию</em>
          </span>
          <span class="btn-quiz-divider"></span>
          <span class="btn-quiz-meta">$150 · 60 мин</span>
        </a>

        <div class="social">
          <a href={SITE.telegramUrl} class="soc-link tg" rel="noopener">
            <span class="soc-dot"></span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.05 2.434 2.42 9.9c-1.34.525-1.33 1.276-.242 1.606l5.05 1.577 11.688-7.372c.553-.334 1.057-.155.641.213L9.117 14.47l-.363 5.439c.523 0 .753-.24 1.046-.524l2.507-2.422 5.21 3.833c.96.528 1.65.256 1.889-.89l3.418-16.081c.349-1.405-.54-2.044-1.772-1.39"/></svg>
            Telegram
          </a>
          <a href={SITE.youtubeUrl} class="soc-link yt" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8M9.6 15.6V8.4l6.2 3.6z"/></svg>
            YouTube
          </a>
        </div>
      </div>
    </div>

    <div class="clock-bar container">
      <div class="clocks">
        <div class="clock active"><span class="clock-dot"></span><span class="clock-name">Куэнка</span><span class="clock-time" id="t-cuenca">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Москва</span><span class="clock-time" id="t-moscow">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Киев</span><span class="clock-time" id="t-kyiv">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Берлин</span><span class="clock-time" id="t-berlin">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Нью-Йорк</span><span class="clock-time" id="t-ny">—:—</span></div>
        <div class="clock"><span class="clock-dot"></span><span class="clock-name">Торонто</span><span class="clock-time" id="t-toronto">—:—</span></div>
      </div>
    </div>
  </section>

  <!-- ============== NUMBERS ============== -->
  <section class="numbers-section noise">
    <div class="numbers-wrap container">
      <div class="numbers-head reveal">
        <h2 class="numbers-title">
          Три цифры,<br>которые <em>описывают</em> опыт
        </h2>
        <p class="numbers-subtitle">
          Главные параметры, по которым я веду русскоязычных клиентов в Эквадоре. Глубина рынка, охват городов и независимость позиции.
        </p>
      </div>

      <div class="numbers-grid reveal-stagger">
        <div class="pillar">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
          <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
          <div class="pillar-num">13<span class="suffix"> лет</span></div>
          <div class="pillar-bottom">
            <div class="pillar-caption">в&nbsp;<em>Латинской Америке</em></div>
            <div class="pillar-divider"></div>
            <div class="pillar-meta">Эквадор + соседние страны</div>
          </div>
        </div>

        <div class="pillar">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
          <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
          <div class="pillar-num">8<span class="suffix">+ лет</span></div>
          <div class="pillar-bottom">
            <div class="pillar-caption">в&nbsp;<em>недвижимости</em></div>
            <div class="pillar-divider"></div>
            <div class="pillar-meta">Due diligence · сделки · аналитика</div>
          </div>
        </div>

        <div class="pillar">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
          <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
          <div class="pillar-num">5</div>
          <div class="pillar-bottom">
            <div class="pillar-caption"><em>городов</em> работы</div>
            <div class="pillar-divider"></div>
            <div class="pillar-meta">Куэнка · Кито · Гуаякиль · Салинас · Манта</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== USLUGI ============== -->
  <section class="services-section">
    <div class="container">
      <div class="services-head reveal">
        <span class="eyebrow gold">Что я делаю</span>
        <h2>Три формата —<br><em>от консультации до сделки</em></h2>
        <p>Все услуги работают по модели consultor inmobiliario&nbsp;+ лицензированный партнёр-корредор.</p>
      </div>

      <div class="services-grid reveal-stagger">
        {services.map((s) => (
          <a href={s.href} class="service-card pillar">
            <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
            <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
            <div class="srv-eyebrow">{s.eyebrow}</div>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <div class="srv-bottom">
              <span class="srv-price">{s.price}</span>
              <span class="srv-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== ЧЕГО НЕ ЖДАТЬ ============== -->
  <section class="not-section">
    <div class="container-narrow">
      <div class="reveal">
        <span class="eyebrow gold">Прозрачность</span>
        <h2>Чего вам <em>не стоит</em> ждать от меня</h2>
      </div>
      <ul class="not-list reveal-stagger">
        <li>Не выступаю лицензированным риэлтором&nbsp;— сделки юридически проводит партнёр-корредор</li>
        <li>У меня нет «своей базы объектов»&nbsp;— подбираю из всего рынка</li>
        <li>Не получаю комиссии от продавцов или агентств&nbsp;— поэтому работаю только на вашей стороне</li>
        <li>Не оформляю ВНЖ in-house&nbsp;— связываю с лицензированным юристом-партнёром</li>
      </ul>
    </div>
  </section>

  <!-- ============== КАТАЛОГ ============== -->
  <section class="catalog-section noise">
    <div class="container">
      <div class="cat-head reveal">
        <span class="eyebrow gold">Каталог знаний</span>
        <h2>Всё про&nbsp;Эквадор<br>для&nbsp;<em>русскоязычных</em></h2>
        <p>Семь категорий: деньги, недвижимость, безопасность, ВНЖ, жизнь, сравнения, бизнес.</p>
      </div>
      <div class="cat-grid reveal-stagger">
        {Object.values(CATEGORIES).map((cat) => (
          <CategoryCard slug={cat.slug} name={cat.name} description={cat.description} />
        ))}
      </div>
      <div class="cat-foot reveal">
        <a href="/znaniya" class="btn btn-gold">Открыть каталог</a>
      </div>
    </div>
  </section>

  <!-- ============== FAQ ============== -->
  <div class="container-narrow">
    <FAQBlock faqs={homeFaqs} skipSchema title="Часто задаваемые" />
  </div>

  <!-- ============== FINAL CTA ============== -->
  <div class="container-narrow">
    <CTABlock variant="commercial" />
  </div>
</BaseLayout>

<style>
  /* ============== HERO ============== */
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
    background: var(--void);
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: contrast(1.05) saturate(0.85) brightness(0.55);
    animation: heroKenBurns 30s ease-in-out infinite alternate;
  }
  .hero-photo-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 3, 16, 0.65) 0%, rgba(7, 3, 16, 0.45) 30%, rgba(7, 3, 16, 0.85) 80%, var(--void) 100%),
      linear-gradient(90deg, rgba(7, 3, 16, 0.7) 0%, transparent 50%, rgba(7, 3, 16, 0.4) 100%);
  }
  @keyframes heroKenBurns {
    0% { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.08) translate(-1%, -1%); }
  }

  .hero-mesh {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse 800px 600px at 75% 40%, rgba(157, 127, 255, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse 600px 500px at 20% 80%, rgba(212, 175, 55, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse 1000px 700px at 90% 10%, rgba(106, 61, 232, 0.10) 0%, transparent 60%);
    background-size: 150% 150%, 150% 150%, 150% 150%;
    animation: heroMesh 30s ease-in-out infinite alternate;
    mix-blend-mode: screen;
    pointer-events: none;
  }
  @keyframes heroMesh {
    0% { background-position: 0% 0%, 0% 0%, 0% 0%; }
    50% { background-position: 50% 100%, 100% 50%, 100% 100%; }
    100% { background-position: 100% 50%, 50% 100%, 0% 100%; }
  }

  .hero-glow {
    position: absolute;
    bottom: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--violet-bright), transparent);
    box-shadow: 0 0 24px var(--violet-glow), 0 0 48px rgba(157, 127, 255, 0.3);
    z-index: 5;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(28px, 3vw, 44px);
    padding-top: clamp(120px, 18vh, 200px);
    padding-bottom: clamp(40px, 6vw, 80px);
  }

  .hero-eyebrow {
    color: var(--gold-champagne);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 160px);
    line-height: 0.92;
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--text-light);
    margin: 0;
    max-width: 1200px;
  }
  .hero-title span { display: block; }
  .hero-title .line-2 { margin-top: 4px; }
  .hero-title .line-3 {
    font-size: clamp(20px, 2.4vw, 34px);
    margin-top: 18px;
    color: var(--ivory-dim);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.2;
    max-width: 720px;
  }
  .hero-title em {
    font-style: italic;
    font-weight: 300;
    background: linear-gradient(180deg, var(--violet-bright) 0%, var(--violet) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    padding-right: 0.08em;
  }

  /* CITIES */
  .cities {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-mute);
    flex-wrap: wrap;
  }
  .cities-line {
    width: clamp(40px, 8vw, 100px);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-champagne), transparent);
  }
  .city {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: color 0.4s;
  }
  .city-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--text-soft);
    transition: all 0.4s;
  }
  .city.active { color: var(--text-light); }
  .city.active .city-dot {
    background: var(--green);
    box-shadow: 0 0 10px rgba(74, 222, 128, 0.6);
  }
  .city-sep { color: var(--text-soft); opacity: 0.4; }

  /* SUB */
  .hero-sub-wrap {
    position: relative;
    padding-left: 24px;
    max-width: 640px;
  }
  .hero-sub-wrap::before {
    content: '';
    position: absolute;
    top: 8px; bottom: 8px; left: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--violet-bright), transparent);
    border-radius: 2px;
  }
  .hero-sub {
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.7;
    color: var(--text-dim);
    font-weight: 300;
    margin: 0;
  }
  .hero-sub em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ACTIONS */
  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }

  .btn-quiz {
    display: inline-flex;
    align-items: stretch;
    background: linear-gradient(135deg, #3D2288 0%, #271458 50%, #1A0F47 100%);
    border: 1px solid rgba(157, 127, 255, 0.3);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.6s var(--ease-premium), box-shadow 0.6s var(--ease-premium), transform 0.5s var(--ease-premium);
    box-shadow:
      0 8px 24px rgba(26, 15, 71, 0.5),
      0 2px 8px rgba(61, 34, 136, 0.35),
      inset 0 1px 0 rgba(157, 127, 255, 0.2),
      inset 0 -1px 0 rgba(15, 8, 41, 0.6);
    position: relative;
  }
  .btn-quiz::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(157, 127, 255, 0.12) 0%, transparent 50%, rgba(157, 127, 255, 0.06) 100%);
    opacity: 0;
    transition: opacity 0.6s var(--ease-premium);
    pointer-events: none;
  }
  .btn-quiz:hover {
    transform: translateY(-2px);
    border-color: rgba(157, 127, 255, 0.55);
    box-shadow:
      0 0 0 1px rgba(157, 127, 255, 0.4),
      0 12px 32px rgba(26, 15, 71, 0.6),
      0 0 40px rgba(106, 61, 232, 0.35),
      0 0 80px rgba(106, 61, 232, 0.2),
      inset 0 1px 0 rgba(157, 127, 255, 0.3);
  }
  .btn-quiz:hover::before { opacity: 1; }

  .btn-quiz-main, .btn-quiz-meta {
    display: inline-flex;
    align-items: center;
    color: var(--text-light);
    white-space: nowrap;
    position: relative;
    z-index: 1;
  }
  .btn-quiz-main {
    padding: 22px 30px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    gap: 12px;
    font-family: var(--font-sans);
  }
  .btn-quiz-main em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ivory);
    background: none;
    -webkit-text-fill-color: var(--ivory);
    transition: color 0.4s;
  }
  .btn-quiz:hover .btn-quiz-main em { color: var(--violet-bright); -webkit-text-fill-color: var(--violet-bright); }
  .btn-quiz-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, rgba(157, 127, 255, 0.3) 50%, transparent 100%);
    margin: 10px 0;
    position: relative;
    z-index: 1;
  }
  .btn-quiz-meta {
    padding: 22px 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ivory-dim);
    transition: color 0.4s;
  }
  .btn-quiz:hover .btn-quiz-meta { color: var(--text-light); }

