    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: 22px;
  }
  @media (max-width: 720px) {
    .city-summary { grid-template-columns: auto 1fr auto; }
    .city-summary-text { grid-column: 1 / -1; padding-left: 60px; margin-top: 4px; }
  }

  .city-icon {
    color: var(--gold-champagne);
    width: 42px; height: 42px;
    border-radius: 50%;
    background: rgba(229, 198, 120, 0.08);
    border: 1px solid rgba(229, 198, 120, 0.25);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
