  .city-detail {
    padding: 0 26px 22px 90px;
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.7;
    font-weight: 300;
  }
  @media (max-width: 720px) { .city-detail { padding-left: 26px; } }
  .city-detail p { margin: 0; }

  /* ============== EXAMPLES SECTION ============== */
  .examples-section {
    padding: clamp(80px, 10vw, 140px) 0;
    background: var(--midnight);
  }
  .examples-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto clamp(48px, 6vw, 72px);
  }
  .examples-head .eyebrow { display: block; margin-bottom: 14px; }
  .examples-head h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    margin: 0 0 18px;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .examples-head em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
