---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { SITE } from '@lib/constants';
---

<BaseLayout
  title="Налоговый калькулятор покупки недвижимости в Эквадоре"
  description="Калькулятор налогов и сборов при покупке недвижимости в Эквадоре: alcabala, регистрация, нотариус. В разработке — пока расчёт по запросу в Telegram."
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Инструменты', href: '/instrumenty' },
      { name: 'Налоговый калькулятор', href: '/instrumenty/nalogovyy-kalkulyator' },
    ]} />

    <article class="page">
      <h1>Налоговый калькулятор покупки недвижимости в&nbsp;Эквадоре</h1>
      <p class="lead">
        Расчёт alcabala, регистрационных сборов и&nbsp;нотариальных расходов под&nbsp;конкретный объект и&nbsp;муниципалитет.
      </p>

      <div class="placeholder">
        <div class="badge">В разработке</div>
        <h2>Скоро будет доступен</h2>
        <p>
          Налоговый калькулятор появится здесь в&nbsp;ближайших обновлениях. Он&nbsp;учтёт alcabala (~1% от&nbsp;кадастровой
          оценки, ставка зависит от&nbsp;муниципалитета), регистрационные сборы (~0.4%), нотариальные расходы
          ($300–600 в&nbsp;зависимости от&nbsp;суммы) и&nbsp;ставку ICUS (impuesto al capital urbano específico)
          по&nbsp;вашей зоне.
        </p>
        <p>
          <strong>Пока:</strong> для&nbsp;точного расчёта под&nbsp;ваш объект и&nbsp;город — напишите в&nbsp;Telegram.
          Отвечу с&nbsp;разбивкой по&nbsp;статьям расходов в&nbsp;течение&nbsp;24&nbsp;часов.
        </p>
        <a href={SITE.telegramUrl} class="btn btn-primary" rel="noopener">Написать в Telegram</a>
      </div>

      <div class="prose">
        <h2>Какие налоги и сборы платит покупатель</h2>
        <ul>
          <li><strong>Alcabala</strong> — налог на передачу имущества, ~1% от кадастровой оценки. Ставка устанавливается муниципалитетом, обычно 0.96–1%.</li>
          <li><strong>Регистрационный сбор</strong> в Registro de la Propiedad — около 0.4% от стоимости сделки.</li>
          <li><strong>Нотариальные расходы</strong> — фиксированная сетка по сумме сделки. На объект $80–150K — $300–500. На объект $300K+ — $500–800.</li>
          <li><strong>Сверка с кадастром и муниципалитетом</strong> по неуплаченным налогам предыдущего собственника — обычно бесплатно или символическая сумма.</li>
        </ul>

        <h2>Что НЕ платит покупатель</h2>
        <ul>
          <li>Комиссию агентства продавца — она на стороне продавца</li>
          <li>Гонорар риэлтора-партнёра по нашей модели — это отдельная договорная сумма, не государственный налог</li>
          <li>Налог на прирост капитала (ganancia ocasional) — это налог продавца</li>
        </ul>

        <h2>Источники</h2>
        <ul>
          <li><a href="https://www.sri.gob.ec/" rel="nofollow noopener" target="_blank">SRI — Servicio de Rentas Internas</a></li>
          <li>Муниципальные сайты (Cuenca, Quito, Guayaquil) для актуальных ставок alcabala</li>
          <li>Тарифы нотариусов — Consejo de la Judicatura</li>
        </ul>
      </div>

      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 8px 0 40px; }
  .page h1 { font-size: 30px; line-height: 1.2; margin: 18px 0 16px; }
  @media (max-width: 640px) { .page h1 { font-size: 24px; } }
  .lead { font-size: 17px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 28px; }

  .placeholder {
    background: var(--accent-light);
    border: 1px solid var(--accent-mid);
    border-radius: 16px;
    padding: 28px 26px;
    text-align: center;
    margin-bottom: 40px;
  }

  .badge {
    display: inline-block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--accent-dark);
    color: #fff;
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 14px;
  }

  .placeholder h2 {
    color: var(--accent-deep);
    font-size: 22px;
    margin: 0 0 12px;
  }

  .placeholder p {
    color: var(--accent-deep);
    opacity: 0.85;
    font-size: 15px;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto 14px;
  }

  .placeholder .btn {
    margin-top: 8px;
  }
</style>
