---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import PriceCalculatorEmbed from '@components/PriceCalculatorEmbed.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
---

<BaseLayout
  title="Калькулятор стоимости сопровождения сделки в Эквадоре"
  description="Бесплатный калькулятор сопровождения сделки покупки недвижимости в Эквадоре. Расчёт фикс-пакета или гибридной модели под ваш бюджет."
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Инструменты', href: '/instrumenty' },
      { name: 'Калькулятор сделки', href: '/instrumenty/kalkulyator-sdelki' },
    ]} />

    <article class="page reveal">
      <span class="eyebrow gold">Калькулятор</span>
      <h1>Калькулятор<br><em>сопровождения</em> сделки</h1>
      <p class="lead">
        Подбирает фикс-пакет или&nbsp;гибридную модель под&nbsp;ваш бюджет. Показывает гонорар, состав работ
        и&nbsp;сроки.
      </p>

      <PriceCalculatorEmbed height="1180px" />

      <div class="prose under">
        <h2>Как использовать</h2>
        <ol>
          <li>Выберите формат присутствия — рядом / на финал / удалённо.</li>
          <li>Укажите бюджет покупки.</li>
          <li>Выберите город и сегмент.</li>
          <li>Калькулятор покажет ориентир по фикс-пакету или гибридной модели.</li>
        </ol>
        <p>
          Это ориентир, не оферта. Финальная стоимость согласовывается на стратегической консультации.
          См. также <a href="/tseny">страницу цен</a> с подробным объяснением модели и FAQ.
        </p>
      </div>

      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 28px;
    font-weight: 300;
  }
  .under { margin-top: 28px; }
</style>
