---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ArticleCard from '@components/ArticleCard.astro';
import CategoryCard from '@components/CategoryCard.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { CATEGORIES, type CategorySlug } from '@lib/constants';
import { collectionPageSchema, breadcrumbListSchema } from '@lib/schema';
import { canonicalUrl } from '@lib/seo';
import { getCollection } from 'astro:content';
import { SITE } from '@lib/constants';

export async function getStaticPaths() {
  return Object.values(CATEGORIES).map((cat) => ({
    params: { category: cat.slug },
  }));
}

const { category } = Astro.params as { category: CategorySlug };
const cat = CATEGORIES[category];

if (!cat) {
  return Astro.redirect('/znaniya');
}

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const articles = allArticles
  .filter((a) => a.data.category === category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const url = canonicalUrl(`/znaniya/${category}`);
const otherCats = Object.values(CATEGORIES).filter((c) => c.slug !== category);

const schemas = [
  collectionPageSchema({
    name: `${cat.name} — каталог знаний об Эквадоре`,
    description: cat.description,
    url,
  }),
  breadcrumbListSchema([
    { name: 'Главная', url: SITE.url },
    { name: 'Знания', url: `${SITE.url}/znaniya` },
    { name: cat.name, url },
  ]),
];
---

<BaseLayout
  title={`${cat.name} — каталог знаний об Эквадоре`}
  description={`${cat.description}. Подробные статьи от независимого консультанта по недвижимости в Эквадоре.`}
  jsonLd={schemas}
>
  <div class="container">
    <Breadcrumbs items={[
      { name: 'Знания', href: '/znaniya' },
      { name: cat.name, href: `/znaniya/${cat.slug}` },
    ]} />

    <article class="page reveal">
      <span class="eyebrow gold">Категория</span>
      <h1>{cat.name}</h1>
      <p class="lead">{cat.description}.</p>

      {articles.length > 0 ? (
        <div class="articles-grid reveal-stagger">
          {articles.map((a) => (
            <ArticleCard
              href={`/znaniya/${a.id}`}
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              pubDate={a.data.pubDate}
            />
          ))}
        </div>
      ) : (
        <div class="empty-state pillar">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
          <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
          <span class="es-eyebrow">Категория готовится</span>
          <h2>В&nbsp;этой категории пока нет статей</h2>
          <p>
            Если у&nbsp;вас есть конкретный вопрос из&nbsp;этой темы&nbsp;— напишите в&nbsp;Telegram, возможно
            ваш вопрос станет следующей публикацией.
          </p>
        </div>
      )}

      <section class="related-cats">
        <span class="eyebrow gold">Смежные темы</span>
        <h2>Связанные категории</h2>
        <div class="cats-grid">
          {otherCats.slice(0, 3).map((c) => (
            <CategoryCard slug={c.slug} name={c.name} description={c.description} />
          ))}
        </div>
      </section>

      <CTABlock variant="category" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1;
    margin: 0 0 18px;
    letter-spacing: -0.03em;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.55;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
    max-width: 720px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 60px;
  }

  .empty-state {
    text-align: center;
    padding: clamp(36px, 4vw, 56px);
    margin-bottom: 60px;
  }
  .es-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
    margin-bottom: 14px;
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.6vw, 28px);
    margin: 0 0 12px;
    color: var(--text-light);
  }
  .empty-state p {
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto;
    font-weight: 300;
  }

  .related-cats { margin: 60px 0 16px; }
  .related-cats .eyebrow { display: block; margin-bottom: 12px; }
  .related-cats h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }
  .cats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }
</style>
