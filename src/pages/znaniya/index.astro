---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CategoryCard from '@components/CategoryCard.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { CATEGORIES } from '@lib/constants';
import { collectionPageSchema } from '@lib/schema';
import { canonicalUrl } from '@lib/seo';
import { getCollection } from 'astro:content';

const url = canonicalUrl('/znaniya');

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const counts = Object.fromEntries(
  Object.values(CATEGORIES).map((cat) => [
    cat.slug,
    allArticles.filter((a) => a.data.category === cat.slug).length,
  ]),
) as Record<string, number>;
---

<BaseLayout
  title="Каталог знаний об Эквадоре"
  description="Полный гид об Эквадоре для русскоязычных: деньги и банки, недвижимость, безопасность, ВНЖ, жизнь, сравнения стран, бизнес. От независимого консультанта."
  jsonLd={collectionPageSchema({
    name: 'Каталог знаний об Эквадоре',
    description: 'Полный гид об Эквадоре для русскоязычных по семи категориям',
    url,
  })}
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Знания', href: '/znaniya' }]} />

    <article class="page reveal">
      <span class="eyebrow gold">Каталог знаний</span>
      <h1>Всё про&nbsp;Эквадор<br>для&nbsp;<em>русскоязычных</em></h1>
      <p class="lead">
        Семь категорий — от&nbsp;денег и&nbsp;банков до&nbsp;сравнения стран. Опираюсь на&nbsp;реальную практику работы
        в&nbsp;недвижимости и&nbsp;13&nbsp;лет жизни в&nbsp;Латинской Америке.
      </p>

      <div class="categories-grid reveal-stagger">
        {Object.values(CATEGORIES).map((cat) => (
          <CategoryCard
            slug={cat.slug}
            name={cat.name}
            description={cat.description}
            count={counts[cat.slug]}
          />
        ))}
      </div>

      {allArticles.length === 0 && (
        <div class="empty-state pillar">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
          <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
          <span class="es-eyebrow">Каталог запускается</span>
          <h2>Структура готова — статьи на подходе</h2>
          <p>
            Если у&nbsp;вас есть конкретный вопрос про&nbsp;Эквадор, на&nbsp;который пока нет статьи&nbsp;— напишите
            в&nbsp;Telegram, возможно ваш вопрос станет следующей публикацией.
          </p>
        </div>
      )}

      <CTABlock variant="category" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
    max-width: 760px;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 48px;
  }

  .empty-state {
    text-align: center;
    padding: clamp(36px, 4vw, 56px);
    margin-bottom: 32px;
  }
  .es-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
    margin-bottom: 14px;
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    margin: 0 0 14px;
    color: var(--text-light);
    letter-spacing: -0.02em;
  }
  .empty-state p {
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.65;
    max-width: 540px;
    margin: 0 auto;
    font-weight: 300;
  }
</style>
