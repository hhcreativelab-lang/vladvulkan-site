---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { canonicalUrl } from '@lib/seo';
import { serviceSchema } from '@lib/schema';

const url = canonicalUrl('/uslugi/proverka-objekta');

const faqs = [
  {
    question: 'Сколько занимает проверка по времени?',
    answer:
      'Стандартно 5–10 рабочих дней с момента получения всех документов от продавца. Если объект на побережье или в небольшом городе с медленным реестром — до 14 дней. Юридическая часть с certificado de gravámenes — 3–5 дней.',
  },
  {
    question: 'Что если по результатам проверки я отказываюсь от объекта?',
    answer:
      'Это абсолютно нормально и часто бывает лучшим результатом. $1500 закрывают работу по проверке независимо от вашего решения. Если найденные риски привели к отказу — у вас на руках письменный отчёт, который вы можете использовать для торга или для обоснования отказа.',
  },
  {
    question: 'Можно ли использовать ваш отчёт для торга?',
    answer:
      'Да. Часто отчёт по due diligence — главный инструмент для скидки от заявленной цены. Найденные обременения, спорные моменты в истории, технические недостатки — это аргументы. Если хотите, чтобы я вёл и переговоры — это можно добавить отдельно или перейти в полный пакет сопровождения.',
  },
  {
    question: 'Засчитывается ли $1500 в пакет сопровождения?',
    answer:
      'Если в течение 90 дней после проверки вы решаете перейти в полный пакет сопровождения по этому же объекту — да, засчитывается. Если переходите по другому объекту — обсуждаем индивидуально.',
  },
  {
    question: 'Кто оформляет сделку, если объект прошёл проверку?',
    answer:
      'Юридическое оформление escritura — через того же лицензированного партнёра-корредора, с которым я работаю. Можно идти дальше как «проверка + минимальное сопровождение у нотариуса» или перейти в полный пакет с переговорами и удалённой схемой по доверенности.',
  },
];
---

<BaseLayout
  title="Проверка объекта недвижимости в Эквадоре — $1500 фикс"
  description="Независимый due diligence объекта недвижимости в Эквадоре. Проверка документов, истории, технического состояния, цены против рынка. $1500 фикс."
  jsonLd={serviceSchema({
    name: 'Проверка объекта недвижимости в Эквадоре (due diligence)',
    description:
      'Независимая проверка объекта недвижимости в Эквадоре, найденного клиентом самостоятельно. Документы, история, физическое состояние, цена против рынка.',
    url,
    priceDescription: '$1500 фиксированная стоимость за полную проверку объекта',
  })}
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Услуги', href: '/uslugi' },
      { name: 'Проверка объекта', href: '/uslugi/proverka-objekta' },
    ]} />

    <article class="page">
      <h1>Проверка объекта недвижимости в&nbsp;Эквадоре — $1500 фикс</h1>
      <p class="lead">
        Вы нашли объект самостоятельно. Я провожу полный due diligence: документы, история собственности,
        техническое состояние, рыночная цена. На&nbsp;выходе — отчёт с&nbsp;конкретными рисками и&nbsp;рекомендацией.
      </p>

      <div class="prose">
        <h2>Что входит</h2>
        <ul>
          <li>Запрос и анализ certificado de gravámenes (обременения, ипотеки, аресты)</li>
          <li>Проверка истории собственности — цепочка переходов прав за 10+ лет</li>
          <li>Физический осмотр: техническое состояние, скрытые дефекты, соответствие плану</li>
          <li>Сверка с кадастром и муниципальным реестром (по неуплаченным налогам и сборам)</li>
          <li>Анализ цены против рынка: 3–5 сравнимых объектов, медиана, отклонение</li>
          <li>Вычитка проекта договора купли-продажи (escritura)</li>
          <li>Письменный отчёт со всеми находками и рекомендацией: покупать / торговаться / отказаться</li>
        </ul>

        <h2>Для кого</h2>
        <ul>
          <li>Вы нашли объект через знакомых, агента или сами и хотите независимый второй взгляд</li>
          <li>Вы доверяете продавцу, но хотите убедиться в чистоте документов</li>
          <li>Вы готовы вести переговоры сами, но нужен профессиональный отчёт для торга</li>
          <li>Вам нужно понять, не переплачиваете ли — против реальной рыночной цены</li>
        </ul>

        <h2>Что НЕ входит (по умолчанию)</h2>
        <ul>
          <li>Переговоры с продавцом — это можно добавить как отдельную услугу или перейти в полный пакет</li>
          <li>Сопровождение у нотариуса при подписании — отдельно или в составе полного пакета</li>
          <li>Регистрация в Registro de la Propiedad — отдельно или в составе пакета</li>
          <li>Связка с юристом по ВНЖ — отдельно</li>
        </ul>

        <h2>Как идёт работа</h2>
        <ol class="steps">
          <li><strong>Бриф (1–2 дня).</strong> Вы передаёте контакт продавца / корредора, доступные документы и фото. Я составляю чек-лист недостающих документов и запрашиваю их.</li>
          <li><strong>Юридическая проверка (3–5 дней).</strong> Certificado de gravámenes, история, налоги, обременения.</li>
          <li><strong>Физическая проверка (1–2 дня).</strong> Лично или через доверенного партнёра по моей сети, если объект вне моих городов.</li>
          <li><strong>Анализ цены (1–2 дня).</strong> Сравнимые объекты, медиана, оценка торга.</li>
          <li><strong>Отчёт (1 день).</strong> Письменный документ + 30-минутный звонок для разбора.</li>
        </ol>
      </div>

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 8px 0 40px; }
  .page h1 { font-size: 32px; line-height: 1.2; margin: 18px 0 18px; }
  @media (max-width: 640px) { .page h1 { font-size: 24px; } }
  .lead { font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 28px; }
  .steps {
    margin: 16px 0 28px;
    padding-left: 20px;
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.65;
  }
  .steps li { margin-bottom: 12px; }
  .steps strong { color: var(--text-primary); }
</style>
