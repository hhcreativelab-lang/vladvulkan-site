---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { canonicalUrl } from '@lib/seo';
import { serviceSchema } from '@lib/schema';

const url = canonicalUrl('/uslugi/proverka-objekta');

const faqs = [
  { question: 'Сколько занимает проверка по времени?', answer: 'Стандартно 5–10 рабочих дней с момента получения всех документов от продавца. Юридическая часть с certificado de gravámenes — 3–5 дней.' },
  { question: 'Что если по результатам я отказываюсь от объекта?', answer: 'Это нормально и часто бывает лучшим результатом. $1500 закрывают работу по проверке независимо от вашего решения. У вас на руках письменный отчёт.' },
  { question: 'Можно ли использовать ваш отчёт для торга?', answer: 'Да. Часто отчёт по due diligence — главный инструмент для скидки от заявленной цены. Если хотите, чтобы я вёл и переговоры — это можно добавить.' },
  { question: 'Засчитывается ли $1500 в пакет сопровождения?', answer: 'Если в течение 90 дней вы решаете перейти в полный пакет по этому же объекту — да, засчитывается.' },
  { question: 'Кто оформляет сделку, если объект прошёл проверку?', answer: 'Юридическое оформление escritura — через того же лицензированного партнёра-корредора, с которым я работаю.' },
];
---

<BaseLayout
  title="Проверка объекта недвижимости в Эквадоре — $1500 фикс"
  description="Независимый due diligence объекта недвижимости в Эквадоре. Проверка документов, истории, технического состояния, цены против рынка. $1500 фикс."
  jsonLd={serviceSchema({
    name: 'Проверка объекта недвижимости в Эквадоре (due diligence)',
    description: 'Независимая проверка объекта недвижимости в Эквадоре, найденного клиентом самостоятельно.',
    url,
    priceDescription: '$1500 фиксированная стоимость за полную проверку объекта',
  })}
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Услуги', href: '/uslugi' },
      { name: 'Проверка объекта', href: '/uslugi/proverka-objekta' },
    ]} />

    <article class="page reveal">
      <span class="eyebrow gold">Только проверка · $1500 фикс</span>
      <h1>Проверка<br><em>объекта</em> недвижимости</h1>
      <p class="lead">
        Вы нашли объект самостоятельно. Я провожу полный due diligence: документы, история, состояние, цена.
        На&nbsp;выходе&nbsp;— отчёт с&nbsp;конкретными рисками и&nbsp;рекомендацией.
      </p>

      <div class="prose">
        <h2>Что входит</h2>
        <ul>
          <li>Запрос и анализ certificado de gravámenes (обременения, ипотеки, аресты)</li>
          <li>Проверка истории собственности — цепочка переходов прав за 10+ лет</li>
          <li>Физический осмотр: техническое состояние, скрытые дефекты</li>
          <li>Сверка с кадастром и муниципальным реестром</li>
          <li>Анализ цены против рынка: 3–5 сравнимых объектов, медиана</li>
          <li>Вычитка проекта договора купли-продажи (escritura)</li>
          <li>Письменный отчёт со всеми находками и рекомендацией</li>
        </ul>

        <h2>Для кого</h2>
        <ul>
          <li>Вы нашли объект через знакомых, агента или сами и хотите независимый второй взгляд</li>
          <li>Вы готовы вести переговоры сами, но нужен профессиональный отчёт для торга</li>
          <li>Вам нужно понять, не переплачиваете ли — против реальной рыночной цены</li>
        </ul>

        <h2>Что НЕ входит (по умолчанию)</h2>
        <ul>
          <li>Переговоры с продавцом — отдельно или в составе полного пакета</li>
          <li>Сопровождение у нотариуса при подписании</li>
          <li>Регистрация в Registro de la Propiedad</li>
          <li>Связка с юристом по ВНЖ</li>
        </ul>

        <h2>Как идёт работа</h2>
        <ol class="steps">
          <li><strong>Бриф (1–2 дня).</strong> Вы передаёте контакт продавца, доступные документы и фото.</li>
          <li><strong>Юридическая проверка (3–5 дней).</strong> Certificado de gravámenes, история, налоги.</li>
          <li><strong>Физическая проверка (1–2 дня).</strong> Лично или через доверенного партнёра.</li>
          <li><strong>Анализ цены (1–2 дня).</strong> Сравнимые объекты, медиана, оценка торга.</li>
          <li><strong>Отчёт (1 день).</strong> Письменный документ + 30-минутный звонок для разбора.</li>
        </ol>
      </div>

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }
  .steps {
    margin: 18px 0 32px;
    padding-left: 0;
    list-style: none;
    counter-reset: step;
  }
  .steps li {
    counter-increment: step;
    padding: 16px 0 16px 56px;
    position: relative;
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.6;
    border-bottom: 1px solid rgba(157, 127, 255, 0.08);
    font-weight: 300;
  }
  .steps li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gold-champagne);
    letter-spacing: 0.1em;
  }
  .steps strong { color: var(--text-light); display: block; margin-bottom: 4px; font-weight: 500; }
  .steps li:last-child { border-bottom: none; }
</style>
