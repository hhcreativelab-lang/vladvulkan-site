---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { canonicalUrl } from '@lib/seo';
import { serviceSchema } from '@lib/schema';

const url = canonicalUrl('/uslugi/konsultatsiya');

const faqs = [
  {
    question: 'Что нужно подготовить к консультации?',
    answer:
      'Кратко в свободной форме: бюджет, сроки, состав семьи (если переезд), цели (жить / инвестировать / диверсифицировать капитал), города, которые рассматриваете, текущая страна. На основе этого я готовлю встречу под вашу задачу.',
  },
  {
    question: 'Что я получу на выходе?',
    answer:
      'Понимание рынка под вашу задачу: какие города и форматы подходят, какие реальные цены м², какая ожидаемая доходность, какие подводные камни именно в вашей конфигурации, какие следующие шаги. Если решаете идти дальше — план сделки. Если нет — у вас остаётся понимание рынка.',
  },
  {
    question: 'Засчитывается ли $150 в пакет, если я выберу сопровождение?',
    answer:
      'Да. $150 за консультацию засчитываются в стоимость фикс-пакета или ретейнера гибридной модели. То есть консультация фактически бесплатна, если идёте дальше — это просто способ начать без полной оплаты пакета.',
  },
  {
    question: 'Можно ли провести консультацию на испанском?',
    answer:
      'Да. Я билингв. Если в семье или в команде есть испаноязычные участники — встречу можно провести на испанском или в смешанном формате.',
  },
  {
    question: 'А если мне нужна вторая консультация?',
    answer:
      'Можно. Каждая последующая 60-минутная консультация — также $150. Они тоже засчитываются в пакет, если в итоге идём в сделку. Часто хватает одной — если задача собрана, дальше работаем уже в формате сопровождения.',
  },
];
---

<BaseLayout
  title="Стратегическая консультация по недвижимости в Эквадоре — $150"
  description="Стратегическая консультация по покупке недвижимости и переезду в Эквадор. 60 минут, $150. Засчитывается в стоимость пакета сопровождения."
  jsonLd={serviceSchema({
    name: 'Стратегическая консультация по недвижимости в Эквадоре',
    description:
      'Независимая стратегическая консультация по покупке недвижимости и релокации в Эквадор. 60 минут разбираем бюджет, цели, города и форматы.',
    url,
    priceDescription: '$150 за 60 минут, засчитывается в стоимость пакета сопровождения',
  })}
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Услуги', href: '/uslugi' },
      { name: 'Стратегическая консультация', href: '/uslugi/konsultatsiya' },
    ]} />

    <article class="page">
      <h1>Стратегическая консультация по&nbsp;недвижимости в&nbsp;Эквадоре — $150 за&nbsp;сессию</h1>
      <p class="lead">
        60&nbsp;минут разбираем вашу ситуацию: бюджет, цели, какие города и&nbsp;форматы недвижимости подходят.
        Засчитывается в&nbsp;стоимость пакета, если идём дальше.
      </p>

      <div class="prose">
        <h2>Что входит</h2>
        <ul>
          <li>Разбор вашей задачи: бюджет, цели (жильё / инвестиция / диверсификация), сроки</li>
          <li>Карта городов и сегментов: где имеет смысл смотреть именно для вашей конфигурации</li>
          <li>Реальные цифры: средние цены м² по городам, ожидаемая доходность аренды, налоги, сборы</li>
          <li>Подводные камни: что часто упускают на старте именно в вашем сегменте</li>
          <li>Сценарии и план: какой формат работы со мной подходит и какой следующий шаг</li>
        </ul>

        <h2>Для кого</h2>
        <ul>
          <li>Вы только начинаете рассматривать Эквадор — нужно понять, имеет ли смысл лично для вас</li>
          <li>Вы между Эквадором и другими странами региона — нужно сравнить под свою задачу</li>
          <li>Вы уже решили — но не знаете, с чего начать: какой город, какой формат, какой бюджет реалистичен</li>
          <li>Вам нужен независимый взгляд перед тем, как принять крупное решение</li>
        </ul>

        <h2>Как засчитывается в пакет</h2>
        <p>
          $150 за консультацию идут в стоимость дальнейшего сопровождения, если вы решаете идти дальше — фикс-пакет
          или гибридная модель, не имеет значения. То есть консультация фактически бесплатна, если из неё рождается
          сделка. Если нет — у вас остаётся понимание рынка и список конкретных шагов.
        </p>

        <h2>Формат</h2>
        <ul>
          <li>60 минут в Zoom (можно и в Telegram-видеозвонке)</li>
          <li>Запись беседы — по запросу</li>
          <li>Конспект ключевых решений и шагов — после встречи в Telegram</li>
          <li>Языки: русский или испанский</li>
        </ul>
      </div>

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 8px 0 40px; }
  .page h1 { font-size: 32px; line-height: 1.2; margin: 18px 0 18px; }
  @media (max-width: 640px) { .page h1 { font-size: 24px; } }
  .lead { font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 28px; }
</style>
