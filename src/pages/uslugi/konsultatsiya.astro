---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { canonicalUrl } from '@lib/seo';
import { serviceSchema } from '@lib/schema';

const url = canonicalUrl('/uslugi/konsultatsiya');

const faqs = [
  { question: 'Что нужно подготовить к консультации?', answer: 'Кратко: бюджет, сроки, состав семьи, цели, города, текущая страна. На основе этого готовлю встречу под вашу задачу.' },
  { question: 'Что я получу на выходе?', answer: 'Понимание рынка под вашу задачу: какие города и форматы подходят, какие реальные цены м², какая ожидаемая доходность, какие подводные камни именно в вашей конфигурации.' },
  { question: 'Засчитывается ли $100 в пакет?', answer: 'Да. $100 за консультацию засчитываются в стоимость фикс-пакета или ретейнера гибридной модели. То есть консультация фактически бесплатна, если идёте дальше.' },
  { question: 'Можно ли провести консультацию на испанском?', answer: 'Да. Я билингв. Если в семье есть испаноязычные участники — встречу можно провести на испанском или в смешанном формате.' },
  { question: 'А если мне нужна вторая консультация?', answer: 'Можно. Каждая последующая 60-минутная — также $100. Они тоже засчитываются в пакет, если в итоге идём в сделку.' },
];
---

<BaseLayout
  title="Стратегическая консультация по недвижимости в Эквадоре — $100"
  description="Стратегическая консультация по покупке недвижимости и переезду в Эквадор. 60 минут, $100. Засчитывается в стоимость пакета сопровождения."
  jsonLd={serviceSchema({
    name: 'Стратегическая консультация по недвижимости в Эквадоре',
    description: 'Независимая стратегическая консультация по покупке недвижимости и релокации в Эквадор.',
    url,
    priceDescription: '$100 за 60 минут, засчитывается в стоимость пакета сопровождения',
  })}
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Услуги', href: '/uslugi' },
      { name: 'Стратегическая консультация', href: '/uslugi/konsultatsiya' },
    ]} />

    <article class="page reveal">
      <span class="eyebrow gold">Первый шаг · $100 · 60 минут</span>
      <h1>Стратегическая<br><em>консультация</em></h1>
      <p class="lead">
        60&nbsp;минут разбираем вашу ситуацию: бюджет, цели, какие города и&nbsp;форматы подходят.
        Засчитывается в&nbsp;стоимость пакета, если идём дальше.
      </p>

      <div class="prose">
        <h2>Что входит</h2>
        <ul>
          <li>Разбор задачи: бюджет, цели (жильё / инвестиция / диверсификация), сроки</li>
          <li>Карта городов и сегментов: где имеет смысл смотреть для вашей конфигурации</li>
          <li>Реальные цифры: цены м², ожидаемая доходность, налоги, сборы</li>
          <li>Подводные камни: что часто упускают на старте в вашем сегменте</li>
          <li>План: какой формат работы со мной подходит и какой следующий шаг</li>
        </ul>

        <h2>Для кого</h2>
        <ul>
          <li>Вы только начинаете рассматривать Эквадор — нужно понять, имеет ли смысл</li>
          <li>Вы между Эквадором и другими странами региона — нужно сравнить</li>
          <li>Вы уже решили — но не знаете, с чего начать</li>
          <li>Вам нужен независимый взгляд перед крупным решением</li>
        </ul>

        <h2>Формат</h2>
        <ul>
          <li>60 минут в Zoom (можно и в Telegram-видеозвонке)</li>
          <li>Запись беседы — по запросу</li>
          <li>Конспект ключевых решений и шагов — после встречи в Telegram</li>
          <li>Языки: русский или испанский</li>
        </ul>
      </div>

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }
</style>
