---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import PriceCalculatorEmbed from '@components/PriceCalculatorEmbed.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { canonicalUrl } from '@lib/seo';
import { serviceSchema } from '@lib/schema';

const url = canonicalUrl('/uslugi/soprovozhdenie-sdelki');

const faqs = [
  {
    question: 'Что входит в фикс-пакет, а что нет?',
    answer:
      'Входит: подбор, due diligence, переговоры, сопровождение у нотариуса, регистрация в реестре. Не входит: alcabala и другие государственные налоги/сборы, гонорар нотариуса, услуги юриста по ВНЖ. Эти платежи — прямые, не через меня.',
  },
  {
    question: 'Сколько объектов я смотрю до выхода на сделку?',
    answer:
      'Обычно 5–12 объектов в short-list, из них 2–4 — финальный осмотр. Зависит от ликвидности сегмента. Элитная и инвестиционная недвижимость — меньше выбор, больше глубина проверки. Жильё в Куэнке для семьи — больше выбор, быстрее цикл.',
  },
  {
    question: 'Как идёт оплата при гибридной модели?',
    answer:
      'Ретейнер при подписании (фиксированная сумма, обычно $2000–4000 в зависимости от бюджета). Остаток — в момент закрытия сделки: процент от финальной цены или минимальный гонорар, что больше. Это страхует обе стороны: вас — от завышенной цены, меня — от работы вхолостую.',
  },
  {
    question: 'Сколько времени занимает сделка?',
    answer:
      'От первой консультации до escritura — обычно 4–10 недель. Подбор и due diligence — 2–6 недель. Подготовка документов и подписание — 1–2 недели. Регистрация в Registro de la Propiedad — 7–15 дней после escritura. Удалённая сделка через доверенность добавляет 1–2 недели на оформление доверенности и пересылку.',
  },
  {
    question: 'А если объект окажется проблемным на этапе due diligence?',
    answer:
      'Это нормальная часть работы. Если документы или состояние объекта не проходят проверку — пишу отчёт с конкретными рисками, и мы возвращаемся к подбору. Сделка идёт только тогда, когда я готов поставить под ней свою экспертизу. Бывает, что отказ от объекта — это лучший результат сделки.',
  },
  {
    question: 'Помогаете с финансированием — ипотекой?',
    answer:
      'Да. Иностранец может взять BIESS-ипотеку при выполнении ряда условий (обычно через работу с местным партнёром или ВНЖ). Также работают банки и кооперативы. Я помогаю выбрать формат, собрать документы и довести до одобрения. Гонорар за это — в составе пакета сопровождения.',
  },
];
---

<BaseLayout
  title="Сопровождение сделки покупки недвижимости в Эквадоре"
  description="Независимое сопровождение покупки недвижимости в Эквадоре от $3000. Подбор объектов, due diligence, переговоры, нотариус. Куэнка, Кито, Гуаякиль."
  jsonLd={serviceSchema({
    name: 'Сопровождение сделки покупки недвижимости в Эквадоре',
    description:
      'Независимое сопровождение сделок покупки недвижимости в Эквадоре. Подбор объектов, due diligence, переговоры, сопровождение у нотариуса.',
    url,
    priceDescription: 'Фикс-пакет от $3000 (бюджет до $120K), гибридная модель от $120K',
  })}
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Услуги', href: '/uslugi' },
      { name: 'Сопровождение сделки', href: '/uslugi/soprovozhdenie-sdelki' },
    ]} />

    <article class="page">
      <h1>Сопровождение сделки покупки недвижимости в&nbsp;Эквадоре</h1>
      <p class="lead">
        Полное сопровождение покупки недвижимости в&nbsp;Эквадоре от&nbsp;$3000 (фикс-пакет до&nbsp;$120K)
        или гибридная модель от&nbsp;$120K. Я веду сделку как независимый консультант на&nbsp;стороне клиента,
        юридическое оформление&nbsp;— лицензированный партнёр-корредор.
      </p>

      <div class="prose">
        <h2>Что входит в сопровождение</h2>
        <ul>
          <li>Стратегическая консультация и брифинг (60 мин, входит в пакет)</li>
          <li>Подбор объектов по всему рынку — корредоры, частные продажи, застройщики</li>
          <li>Due diligence: проверка документов, certificado de gravámenes, истории собственника, физическое состояние</li>
          <li>Торг и переговоры от вашего имени — стандартная скидка от заявленной 8–18%</li>
          <li>Сопровождение у нотариуса с участием партнёра-корредора, перевод с испанского</li>
          <li>Регистрация перехода права в Registro de la Propiedad</li>
          <li>Связка с юристом-партнёром по ВНЖ (если нужен — гонорар юристу платите ему напрямую)</li>
          <li>Отчётность и ведение сделки до полного закрытия</li>
        </ul>

        <h2>Три формата работы</h2>
        <ul>
          <li><strong>Рядом</strong> — вы в Эквадоре, осматриваете объекты сами, я даю экспертную оценку, организую проверки и веду переговоры.</li>
          <li><strong>На финал</strong> — я отбираю кандидатов и провожу первичные осмотры, вы прилетаете на финальный осмотр и подписание.</li>
          <li><strong>Удалённо</strong> — всё через нотариальную доверенность, от первой консультации до получения ключей. Подходит, если переезд после покупки.</li>
        </ul>

        <h2>Модель ценообразования</h2>
        <p>
          <strong>Фикс-пакет</strong> для бюджетов до $120K — фиксированная цена за полное сопровождение. Оплата 50/50:
          половина при подписании договора на услугу, половина при подписании escritura.
        </p>
        <p>
          <strong>Гибридная модель</strong> для бюджетов от $120K — ретейнер при подписании + процент от финальной цены сделки
          (3% на $120K → 1.2% на $1.5M+) или минимальный гонорар, что больше. Эта модель даёт мне прямой стимул сторговать
          вам больше.
        </p>

        <h2>Стоимость</h2>
      </div>

      <PriceCalculatorEmbed />

      <FAQBlock faqs={faqs} skipSchema={false} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 8px 0 40px; }
  .page h1 { font-size: 34px; line-height: 1.2; margin: 18px 0 18px; }
  @media (max-width: 640px) { .page h1 { font-size: 26px; } }
  .lead { font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 28px; }
</style>
