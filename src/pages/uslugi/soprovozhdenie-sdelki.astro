---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import PriceCalculatorEmbed from '@components/PriceCalculatorEmbed.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { canonicalUrl } from '@lib/seo';
import { serviceSchema } from '@lib/schema';

const url = canonicalUrl('/uslugi/soprovozhdenie-sdelki');

const faqs = [
  { question: 'Что входит в фикс-пакет, а что нет?', answer: 'Входит: подбор, due diligence, переговоры, сопровождение у нотариуса, регистрация. Не входит: alcabala и государственные налоги, гонорар нотариуса, услуги юриста по ВНЖ.' },
  { question: 'Сколько объектов я смотрю до выхода на сделку?', answer: 'Обычно 5–12 объектов в short-list, из них 2–4 — финальный осмотр. Зависит от ликвидности сегмента.' },
  { question: 'Как идёт оплата при гибридной модели?', answer: 'Ретейнер при подписании ($2000–4000). Остаток — в момент закрытия: процент от финальной цены или минимальный гонорар.' },
  { question: 'Сколько времени занимает сделка?', answer: 'От первой консультации до escritura — 4–10 недель. Регистрация после escritura — 7–15 дней.' },
  { question: 'А если объект окажется проблемным?', answer: 'Пишу отчёт с конкретными рисками — мы возвращаемся к подбору. Сделка идёт только тогда, когда я готов поставить под ней свою экспертизу.' },
  { question: 'Помогаете с финансированием — ипотекой?', answer: 'Да. Иностранец может взять BIESS-ипотеку при выполнении ряда условий. Также банки и кооперативы. Гонорар за это — в составе пакета.' },
];
---

<BaseLayout
  title="Сопровождение сделки покупки недвижимости в Эквадоре"
  description="Независимое сопровождение покупки недвижимости в Эквадоре от $3000. Подбор объектов, due diligence, переговоры, нотариус. Куэнка, Кито, Гуаякиль."
  jsonLd={serviceSchema({
    name: 'Сопровождение сделки покупки недвижимости в Эквадоре',
    description: 'Независимое сопровождение сделок покупки недвижимости в Эквадоре. Подбор объектов, due diligence, переговоры, сопровождение у нотариуса.',
    url,
    priceDescription: 'Фикс-пакет от $3000 (бюджет до $120K), гибридная модель от $120K',
  })}
>
  <div class="container-narrow">
    <Breadcrumbs items={[
      { name: 'Услуги', href: '/uslugi' },
      { name: 'Сопровождение сделки', href: '/uslugi/soprovozhdenie-sdelki' },
    ]} />

    <article class="page reveal">
      <span class="eyebrow gold">Полный пакет</span>
      <h1>Сопровождение<br><em>сделки</em> с&nbsp;недвижимостью</h1>
      <p class="lead">
        Полное сопровождение покупки от&nbsp;$3000 (фикс-пакет до&nbsp;$120K) или гибридная модель от&nbsp;$120K.
        Юридическое оформление&nbsp;— лицензированный партнёр-корредор.
      </p>

      <div class="prose">
        <h2>Что входит в сопровождение</h2>
        <ul>
          <li>Стратегическая консультация и брифинг (60 мин, входит в пакет)</li>
          <li>Подбор объектов по всему рынку — корредоры, частные продажи, застройщики</li>
          <li>Due diligence: certificado de gravámenes, история, физическое состояние</li>
          <li>Торг и переговоры — стандартная скидка от заявленной 8–18%</li>
          <li>Сопровождение у нотариуса с участием партнёра-корредора, перевод с испанского</li>
          <li>Регистрация перехода права в Registro de la Propiedad</li>
          <li>Связка с юристом-партнёром по ВНЖ (если нужен)</li>
          <li>Отчётность и ведение сделки до полного закрытия</li>
        </ul>

        <h2>Три формата работы</h2>
        <ul>
          <li><strong>Рядом</strong> — вы в Эквадоре, осматриваете объекты сами, я даю экспертную оценку и веду переговоры.</li>
          <li><strong>На финал</strong> — я отбираю кандидатов, вы прилетаете на финальный осмотр и подписание.</li>
          <li><strong>Удалённо</strong> — всё через нотариальную доверенность, от первой консультации до получения ключей.</li>
        </ul>

        <h2>Стоимость</h2>
      </div>

      <PriceCalculatorEmbed />

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.5vw, 70px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }
</style>
