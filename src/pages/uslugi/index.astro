---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Icon from '@components/Icon.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import { SITE } from '@lib/constants';

const services = [
  {
    href: '/uslugi/konsultatsiya',
    icon: 'compass',
    eyebrow: 'Первый шаг',
    badge: '$100 · 60 мин',
    title: 'Стратегическая консультация',
    description: '60 минут разбираем вашу ситуацию: бюджет, цели, какие города и форматы недвижимости подходят.',
    forWhom: 'Для тех, кто на стадии «понять рынок и принять решение». Удобный первый шаг.',
  },
  {
    href: '/uslugi/proverka-objekta',
    icon: 'shield-check',
    eyebrow: 'Только проверка',
    badge: '$1000 фикс',
    title: 'Проверка объекта',
    description: 'Вы нашли объект сами. Я проверяю документы, историю, технику, вычитываю договор и веду торг.',
    forWhom: 'Для тех, у кого уже есть конкретный объект и нужен независимый второй взгляд + торг.',
  },
  {
    href: '/uslugi/soprovozhdenie-sdelki',
    icon: 'handshake',
    eyebrow: 'Полный пакет',
    badge: 'От $3000 / гибрид',
    title: 'Сопровождение сделки',
    description: 'Полное ведение покупки: подбор объекта по всему рынку, due diligence, переговоры, сопровождение у нотариуса.',
    forWhom: 'Для тех, кто хочет переложить процесс целиком — от первой консультации до получения ключей.',
  },
  {
    href: SITE.telegramUrl,
    external: true,
    icon: 'gem',
    eyebrow: 'Индивидуально',
    badge: 'По запросу',
    title: 'Инвестиционные возможности',
    description: 'Есть проект, объект или идея для инвестиций в Эквадоре? Напишите в Telegram — рассмотрим и подскажем, чем сможем помочь.',
    forWhom: 'Для тех, у кого есть конкретное предложение или нестандартный сценарий.',
  },
];
---

<BaseLayout
  title="Услуги — независимая экспертиза по недвижимости в Эквадоре"
  description="Четыре формата работы: стратегическая консультация, проверка объекта, полное сопровождение сделки и индивидуальные инвестиционные запросы."
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'Услуги', href: '/uslugi' }]} />

    <article class="page reveal">
      <span class="eyebrow gold">Четыре формы работы</span>
      <h1>От&nbsp;консультации<br><em>до&nbsp;сделки и&nbsp;инвестиций</em></h1>
      <p class="lead">
        Подберите формат под&nbsp;свою задачу. Сделки оформляются юридически через лицензированного партнёра-корредора&nbsp;— я&nbsp;на&nbsp;пути получения собственной лицензии.
      </p>

      <div class="services reveal-stagger">
        {services.map((s) => (
          <a href={s.href} class="srv-card frame-bar" rel={s.external ? 'noopener' : undefined}>
            <div class="srv-icon"><Icon name={s.icon} size={32} stroke={1.25} /></div>
            <div class="srv-top">
              <div class="srv-eyebrow">{s.eyebrow}</div>
              <span class="srv-badge">{s.badge}</span>
            </div>
            <h2>{s.title}</h2>
            <p>{s.description}</p>
            <div class="for-whom"><strong>Для кого:</strong> {s.forWhom}</div>
            <span class="srv-arrow">Подробнее →</span>
          </a>
        ))}
      </div>

      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 72px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }
  .services {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-bottom: 40px;
  }
  .srv-card {
    display: block;
    text-decoration: none;
    padding: clamp(28px, 3.5vw, 40px);
  }
  .srv-icon {
    color: var(--gold-champagne);
    margin-bottom: 18px;
  }
  .srv-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    flex-wrap: wrap;
    gap: 10px;
  }
  .srv-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
  }
  .srv-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 5px 14px;
    border-radius: 999px;
    background: rgba(157, 127, 255, 0.08);
    border: 1px solid rgba(157, 127, 255, 0.25);
    color: var(--violet-bright);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .srv-card h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 34px);
    margin: 0 0 12px;
    color: var(--text-light);
    letter-spacing: -0.02em;
  }
  .srv-card p {
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.6;
    margin: 0 0 16px;
    font-weight: 300;
  }
  .for-whom {
    color: var(--text-dim);
    font-size: 13.5px;
    line-height: 1.55;
    padding-top: 14px;
    border-top: 1px solid rgba(157, 127, 255, 0.1);
    margin-bottom: 14px;
    font-weight: 300;
  }
  .for-whom strong { color: var(--gold-champagne); font-weight: 500; }
  .srv-arrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--violet-bright);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
</style>
