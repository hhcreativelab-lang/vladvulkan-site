---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';

const services = [
  {
    href: '/uslugi/soprovozhdenie-sdelki',
    badge: 'От $3000 / гибрид',
    title: 'Сопровождение сделки',
    description:
      'Полное ведение покупки: подбор объекта по всему рынку, due diligence, переговоры, сопровождение у нотариуса. Юридическое оформление — лицензированный партнёр-корредор.',
    forWhom: 'Для тех, кто хочет переложить процесс целиком — от первой консультации до получения ключей.',
  },
  {
    href: '/uslugi/konsultatsiya',
    badge: '$150 / 60 мин',
    title: 'Стратегическая консультация',
    description:
      '60 минут разбираем вашу ситуацию: бюджет, цели, какие города и форматы недвижимости подходят. Засчитывается в стоимость пакета, если идём дальше.',
    forWhom: 'Для тех, кто на стадии «понять рынок и принять решение». Удобный первый шаг.',
  },
  {
    href: '/uslugi/proverka-objekta',
    badge: '$1500 фикс',
    title: 'Проверка объекта',
    description:
      'Вы нашли объект сами. Я проверяю документы, историю, технику, вычитываю договор и веду торг. Юридическое оформление — также через партнёра-корредора.',
    forWhom: 'Для тех, у кого уже есть конкретный объект и нужен независимый второй взгляд + торг.',
  },
];
---

<BaseLayout
  title="Услуги — независимая консультация по недвижимости в Эквадоре"
  description="Три формата работы: сопровождение сделки, стратегическая консультация, проверка объекта. Прозрачная модель и фиксированные гонорары."
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'Услуги', href: '/uslugi' }]} />

    <article class="page">
      <h1>Услуги</h1>
      <p class="lead">
        Три формата под разные стадии — от&nbsp;первой консультации до&nbsp;полного сопровождения сделки.
        Все услуги работают по&nbsp;модели consultor inmobiliario&nbsp;+ лицензированный партнёр-корредор.
      </p>

      <div class="services">
        {services.map((s) => (
          <a href={s.href} class="service-card card">
            <span class="badge">{s.badge}</span>
            <h2>{s.title}</h2>
            <p>{s.description}</p>
            <div class="for-whom"><strong>Для кого:</strong> {s.forWhom}</div>
            <span class="arrow">Подробнее →</span>
          </a>
        ))}
      </div>

      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 8px 0 40px; }
  .page h1 { font-size: 36px; line-height: 1.2; margin: 18px 0 16px; }
  @media (max-width: 640px) { .page h1 { font-size: 28px; } }
  .lead { font-size: 18px; line-height: 1.6; color: var(--text-secondary); margin: 0 0 28px; }

  .services {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 32px;
  }

  .service-card {
    display: block;
    text-decoration: none;
    color: var(--text-primary);
  }

  .badge {
    display: inline-block;
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--accent-light);
    color: var(--accent-deep);
    font-weight: 500;
    margin-bottom: 10px;
  }

  .service-card h2 {
    font-size: 22px;
    margin: 0 0 10px;
  }

  .service-card p {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 12px;
  }

  .for-whom {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.5;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    margin-bottom: 12px;
  }

  .for-whom strong {
    color: var(--text-primary);
    font-weight: 500;
  }

  .arrow {
    color: var(--accent-dark);
    font-size: 14px;
  }
</style>
