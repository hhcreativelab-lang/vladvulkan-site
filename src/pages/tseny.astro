---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import PriceCalculatorEmbed from '@components/PriceCalculatorEmbed.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';

const faqs = [
  {
    question: 'Что выгоднее — фикс или гибрид?',
    answer: 'До бюджета $120 000 фикс почти всегда выгоднее по абсолютной сумме. От $120 000 гибридная модель даёт чёткий стимул сторговать вам больше — мой процент считается от финальной цены сделки.',
  },
  {
    question: 'Когда платить?',
    answer: 'Фикс-пакет: 50% при подписании договора на услугу, 50% при подписании escritura. Гибрид: ретейнер при подписании, остаток (процент или минимальный гонорар — что больше) при закрытии.',
  },
  {
    question: 'Что если сделка не состоялась?',
    answer: 'В фикс-пакете предоплата 50% покрывает работу по подбору и due diligence — не возвращается. В гибриде ретейнер также не возвращается. Это страхует мой риск работать «вхолостую».',
  },
  {
    question: 'А ВНЖ-юрист — это за отдельную плату?',
    answer: 'Да. Гонорар юриста-партнёра по ВНЖ — от $1300 — вы платите ему напрямую. Я не зарабатываю на этой связке.',
  },
  {
    question: 'Налоги при покупке — кто их оплачивает?',
    answer: 'Покупатель оплачивает alcabala (~1% от кадастровой оценки), регистрационные сборы (~0.4%), нотариальные расходы ($300–600). Это вне моего гонорара.',
  },
];
---

<BaseLayout
  title="Стоимость сопровождения сделки с недвижимостью в Эквадоре"
  description="Цены на услуги независимого консультанта по недвижимости в Эквадоре. Фикс-пакет до $120K и гибридная модель от $120K. Калькулятор расчёта."
>
  <div class="container-narrow">
    <Breadcrumbs items={[{ name: 'Цены', href: '/tseny' }]} />

    <article class="page reveal">
      <span class="eyebrow gold">Прозрачность</span>
      <h1>Стоимость<br><em>сопровождения сделки</em></h1>
      <p class="lead">
        Две модели — фикс-пакет до&nbsp;$120K и&nbsp;гибридная от&nbsp;$120K. Стратегическая консультация $150 засчитывается в&nbsp;пакет.
      </p>

      <div class="prose">
        <h2>Фикс-пакет (бюджет до $120K)</h2>
        <p>Фиксированная цена за полное сопровождение сделки. Оплата 50/50.</p>
        <ul>
          <li>Стратегический брифинг и план</li>
          <li>Подбор объектов из всего рынка</li>
          <li>Due diligence (документы, история, технический осмотр)</li>
          <li>Переговоры и торг от вашего имени</li>
          <li>Сопровождение у нотариуса с участием партнёра-корредора</li>
          <li>Регистрация в Registro de la Propiedad</li>
        </ul>

        <h2>Гибридная модель (бюджет от $120K)</h2>
        <p>Ретейнер + процент от финальной цены сделки. Ставка снижается с ростом бюджета:</p>
        <ul>
          <li>3% на бюджете $120K</li>
          <li>2% на бюджете $300K</li>
          <li>1.5% на бюджете $700K</li>
          <li>1.2% на бюджете $1.5M+</li>
        </ul>

        <h2>Стратегическая консультация — $150</h2>
        <p>60 минут разбираем вашу ситуацию: бюджет, цели, города, формат. $150 засчитываются в стоимость пакета, если идём дальше.</p>

        <h2>Проверка объекта — $1500 фикс</h2>
        <p>Подходит, если вы уже определились с объектом и хотите независимый второй взгляд. Полный due diligence + торг.</p>

        <h2>Калькулятор</h2>
        <p>Подберите формат и&nbsp;бюджет&nbsp;— посмотрите ориентировочную стоимость:</p>
      </div>

      <PriceCalculatorEmbed />

      <FAQBlock faqs={faqs} />
      <CTABlock variant="commercial" />
      <DisclaimerBlock />
    </article>
  </div>
</BaseLayout>

<style>
  .page { padding: 12px 0 40px; }
  .page > .eyebrow { display: block; margin: 16px 0 18px; }
  .page h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 80px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }
  .page h1 em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 36px;
    font-weight: 300;
  }
</style>
