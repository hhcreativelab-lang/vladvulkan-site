---
import { SITE, DISCLAIMER, CATEGORIES } from '@lib/constants';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-glow" aria-hidden="true"></div>
  <div class="container">
    <div class="footer-top">
      <div class="brand-col">
        <a href="/" class="brand">Влад&nbsp;<em>Вулкан</em></a>
        <p class="brand-desc">
          Независимая консультация по&nbsp;недвижимости в&nbsp;Эквадоре. Куэнка, Кито, Гуаякиль, Салинас, Манта.
        </p>
        <div class="brand-meta">
          <span class="eyebrow gold">Cuenca · Ecuador</span>
        </div>
      </div>

      <div class="cols">
        <div class="col">
          <h4 class="col-title">Услуги</h4>
          <ul>
            <li><a href="/uslugi/soprovozhdenie-sdelki">Сопровождение сделки</a></li>
            <li><a href="/uslugi/konsultatsiya">Стратегическая консультация</a></li>
            <li><a href="/uslugi/proverka-objekta">Проверка объекта</a></li>
            <li><a href="/tseny">Цены</a></li>
          </ul>
        </div>

        <div class="col">
          <h4 class="col-title">Знания</h4>
          <ul>
            {Object.values(CATEGORIES).slice(0, 5).map((cat) => (
              <li><a href={`/znaniya/${cat.slug}`}>{cat.name}</a></li>
            ))}
            <li><a href="/znaniya">Все категории →</a></li>
          </ul>
        </div>

        <div class="col">
          <h4 class="col-title">Связь</h4>
          <ul>
            <li><a href={SITE.telegramUrl} rel="noopener">Telegram</a></li>
            <li><a href={SITE.youtubeUrl} rel="noopener">YouTube</a></li>
            <li><a href={`mailto:${SITE.email}`}>Email</a></li>
            <li><a href="/kontakty">Все контакты</a></li>
          </ul>
        </div>

        <div class="col">
          <h4 class="col-title">Сайт</h4>
          <ul>
            <li><a href="/kto-ya">О Владе</a></li>
            <li><a href="/kak-rabotaem">Как работаем</a></li>
            <li><a href="/instrumenty">Инструменты</a></li>
            <li><a href="/rss.xml">RSS</a></li>
          </ul>
        </div>
      </div>
    </div>

    <hr class="hairline" />

    <div class="disclaimer-block">
      <div class="dsc-mark">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10z"/><path d="m9 12 2 2 4-4"/>
        </svg>
      </div>
      <p>
        <strong>Независимый эксперт.</strong>
        {DISCLAIMER.ru.replace('Независимый эксперт. ', '')}
      </p>
    </div>

    <div class="footer-bottom">
      <span>© {year} {SITE.brandName}. Все права защищены.</span>
      <a href="/politika-konfidentsialnosti">Политика конфиденциальности</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--midnight);
    padding: clamp(80px, 10vw, 140px) 0 36px;
    margin-top: clamp(80px, 10vw, 140px);
    overflow: hidden;
    border-top: 1px solid rgba(157, 127, 255, 0.08);
  }

  .footer-glow {
    position: absolute;
    top: -1px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--violet-bright), transparent);
    box-shadow: 0 0 20px var(--violet-glow);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 3fr;
    gap: 60px;
    margin-bottom: 60px;
  }
  @media (max-width: 880px) {
    .footer-top { grid-template-columns: 1fr; gap: 48px; }
  }

  .brand {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    color: var(--text-light);
    text-decoration: none;
    line-height: 1;
    margin-bottom: 18px;
    display: inline-block;
  }
  .brand:hover { color: var(--text-light); opacity: 0.85; }
  .brand em {
    font-style: italic;
    background: linear-gradient(180deg, var(--violet-bright), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .brand-desc {
    color: var(--text-dim);
    font-size: 14.5px;
    line-height: 1.65;
    max-width: 320px;
    margin-bottom: 20px;
    font-weight: 300;
  }

  .cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 36px;
  }
  @media (max-width: 720px) { .cols { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 460px) { .cols { grid-template-columns: 1fr; } }

  .col-title {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--gold-champagne);
    margin: 0 0 18px;
    font-weight: 400;
  }

  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .col a {
    color: var(--text-dim);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.3s var(--ease-premium);
  }
  .col a:hover { color: var(--violet-bright); }

  .hairline {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(157, 127, 255, 0.2), transparent);
    margin: 0 0 36px;
  }

  .disclaimer-block {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 22px 26px;
    border: 1px solid rgba(229, 198, 120, 0.18);
    background: rgba(229, 198, 120, 0.03);
    border-radius: 4px;
    margin-bottom: 32px;
  }
  .dsc-mark {
    flex-shrink: 0;
    color: var(--gold-champagne);
    width: 28px;
    height: 28px;
    margin-top: 2px;
  }
  .dsc-mark svg { width: 100%; height: 100%; }
  .disclaimer-block p {
    margin: 0;
    color: var(--text-dim);
    font-size: 13px;
    line-height: 1.65;
    font-weight: 300;
  }
  .disclaimer-block strong { color: var(--gold-champagne); font-weight: 500; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-soft);
    letter-spacing: 0.05em;
  }
  .footer-bottom a {
    color: var(--text-soft);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-bottom a:hover { color: var(--gold-champagne); }
</style>
