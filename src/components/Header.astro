---
import { SITE, NAV } from '@lib/constants';

interface Props {
  variant?: 'default' | 'overlay';
}

const { variant = 'default' } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<div class:list={["site-header nav-wrap", variant]}>
  <nav class="nav container" aria-label="Основная навигация">
    <a href="/" class="nav-logo" aria-label="Влад Вулкан — главная">
      <span>Влад&nbsp;<em>Вулкан</em></span>
    </a>

    <ul class="nav-menu">
      {NAV.primary.map((item) => {
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isActive = currentPath === itemPath || currentPath.startsWith(itemPath + '/');
        return (
          <li><a href={item.href} class:list={[{ active: isActive }]}>{item.label}</a></li>
        );
      })}
    </ul>

    <div class="nav-right">
      <a href={SITE.telegramUrl} class="nav-cta" rel="noopener" aria-label="Telegram">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
        </svg>
        Telegram
      </a>
      <div class="nav-lang" aria-label="Язык">
        <span class="active">RU</span>
        <span>·</span>
        <span>ES</span>
      </div>
    </div>
  </nav>
</div>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 22px 0;
    transition: background 0.4s var(--ease-premium), border-color 0.4s, padding 0.4s;
    border-bottom: 1px solid transparent;
  }
  .nav-wrap.scrolled {
    background: rgba(7, 3, 16, 0.85);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-bottom-color: rgba(157, 127, 255, 0.1);
    padding: 14px 0;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--text-light);
    font-family: var(--font-display);
    font-size: clamp(20px, 1.8vw, 26px);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1;
    transition: opacity 0.3s;
  }
  .nav-logo:hover { opacity: 0.85; color: var(--text-light); }
  .nav-logo em {
    font-style: italic;
    font-weight: 300;
    background: linear-gradient(180deg, var(--violet-bright) 0%, var(--violet) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: clamp(20px, 2.5vw, 38px);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-menu a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.01em;
    position: relative;
    padding: 6px 0;
    transition: color 0.4s var(--ease-premium);
    font-family: var(--font-sans);
  }
  .nav-menu a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--gold-champagne);
    transition: right 0.4s var(--ease-premium);
  }
  .nav-menu a:hover { color: var(--text-light); }
  .nav-menu a:hover::after { right: 0; }
  .nav-menu a.active {
    color: var(--text-light);
  }
  .nav-menu a.active::after { right: 0; }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    background: rgba(229, 198, 120, 0.04);
    border: 1px solid rgba(229, 198, 120, 0.35);
    border-radius: 2px;
    color: var(--gold-champagne);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.6s var(--ease-premium), box-shadow 0.6s var(--ease-premium), background 0.6s var(--ease-premium);
  }
  .nav-cta:hover {
    border-color: var(--gold-champagne);
    background: rgba(229, 198, 120, 0.08);
    color: var(--gold-champagne);
    box-shadow:
      0 0 0 1px rgba(229, 198, 120, 0.4),
      0 0 20px rgba(229, 198, 120, 0.25),
      0 0 40px rgba(229, 198, 120, 0.15),
      inset 0 0 20px rgba(229, 198, 120, 0.08);
  }
  .nav-cta svg { width: 14px; height: 14px; transition: transform 0.4s var(--ease-premium); }
  .nav-cta:hover svg { transform: rotate(-10deg) scale(1.1); }

  .nav-lang {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--text-mute);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .nav-lang .active { color: var(--gold-champagne); }
  .nav-lang span:nth-child(2) { margin: 0 8px; color: var(--text-soft); }

  @media (max-width: 1024px) {
    .nav-menu { display: none; }
  }
  @media (max-width: 540px) {
    .nav-lang { display: none; }
    .nav-cta { padding: 10px 16px; font-size: 10px; }
    .nav-wrap { padding: 16px 0; }
    .nav-wrap.scrolled { padding: 12px 0; }
  }
</style>
