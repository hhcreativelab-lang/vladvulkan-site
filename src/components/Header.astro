---
import { SITE, NAV } from '@lib/constants';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${SITE.brandName} — главная`}>
      <span class="brand-mark" aria-hidden="true">В</span>
      <span class="brand-text">
        <span class="brand-name">{SITE.brandName}</span>
        <span class="brand-tagline">{SITE.brandTagline}</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Основная навигация">
      <ul>
        {NAV.primary.map((item) => {
          const itemPath = item.href.replace(/\/$/, '') || '/';
          const isActive = currentPath === itemPath || currentPath.startsWith(itemPath + '/');
          return (
            <li>
              <a href={item.href} class:list={["nav-link", { active: isActive }]}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <a href={SITE.telegramUrl} class="btn btn-primary header-cta" rel="noopener">
      Написать в Telegram
    </a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
    background-color: color-mix(in oklab, var(--bg) 92%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 14px 20px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    text-decoration: none;
    margin-right: auto;
  }

  .brand-mark {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent-dark);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 18px;
    letter-spacing: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand-name {
    font-size: 16px;
    font-weight: 600;
  }

  .brand-tagline {
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .primary-nav ul {
    display: flex;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    padding: 8px 12px;
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 14px;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-surface);
  }

  .nav-link.active {
    color: var(--accent-deep);
    background: var(--accent-light);
  }

  .header-cta {
    font-size: 14px;
    padding: 10px 18px;
  }

  @media (max-width: 960px) {
    .primary-nav { display: none; }
  }

  @media (max-width: 540px) {
    .brand-tagline { display: none; }
    .header-cta { padding: 9px 14px; font-size: 13px; }
    .header-inner { gap: 10px; padding: 12px 16px; }
  }
</style>
