---
import { SITE } from '@lib/constants';

type Variant = 'info' | 'commercial' | 'category';

interface Props {
  variant?: Variant;
  heading?: string;
  text?: string;
  ctaLabel?: string;
}

const { variant = 'info', heading, text, ctaLabel } = Astro.props;

const presets: Record<Variant, { heading: string; text: string; ctaLabel: string }> = {
  info: {
    heading: 'Нужна помощь с покупкой недвижимости в Эквадоре?',
    text: 'Я — Влад Вулкан, независимый эксперт. Помогаю русскоязычным клиентам разобраться с рынком Эквадора, проверить объекты, провести сделку — на стороне клиента. Стратегическая консультация — 60 минут, $100. Если идём дальше — сумма засчитывается в пакет.',
    ctaLabel: 'Написать в Telegram',
  },
  commercial: {
    heading: 'Готовы обсудить вашу задачу?',
    text: 'Расскажите коротко в Telegram: бюджет, тип объекта, город. Отвечу в течение 24 часов. Если нужен глубокий разбор — назначу стратегическую консультацию ($100, 60 минут).',
    ctaLabel: 'Написать в Telegram',
  },
  category: {
    heading: 'В каталоге не нашли ответ?',
    text: 'Если у вас конкретный вопрос про Эквадор, на который нет статьи — напишите. Возможно, ваш вопрос станет следующей публикацией. Если нужна персональная консультация — $100 за 60 минут.',
    ctaLabel: 'Написать в Telegram',
  },
};

const preset = presets[variant];
const finalHeading = heading ?? preset.heading;
const finalText = text ?? preset.text;
const finalLabel = ctaLabel ?? preset.ctaLabel;
---

<section class="cta-section reveal" aria-labelledby="cta-heading">
  <div class="cta-card">
    <div class="cta-eyebrow">
      <span></span>Стратегическая консультация
    </div>
    <h2 id="cta-heading">{finalHeading}</h2>
    <p>{finalText}</p>
    <a href={SITE.telegramUrl} class="btn btn-violet" rel="noopener">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
      </svg>
      {finalLabel}
    </a>
  </div>
</section>

<style>
  .cta-section {
    margin: clamp(60px, 8vw, 100px) 0 40px;
  }

  .cta-card {
    position: relative;
    background: linear-gradient(180deg, rgba(22, 20, 26, 0.75) 0%, rgba(16, 14, 20, 0.85) 100%);
    border: 1px solid rgba(157, 127, 255, 0.12);
    border-radius: 8px;
    padding: clamp(40px, 5vw, 64px);
    text-align: center;
    backdrop-filter: blur(12px);
    overflow: hidden;
  }

  .cta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
    margin-bottom: 24px;
  }
  .cta-eyebrow span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px rgba(74, 222, 128, 0.7);
    animation: pulse 2s ease-in-out infinite;
  }

  .cta-card h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.1;
    margin: 0 0 18px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: -0.02em;
    /* Фиолетовый градиент для заголовка CTA */
    background: linear-gradient(180deg, var(--violet-bright) 0%, var(--violet) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .cta-card p {
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--text-dim);
    max-width: 640px;
    margin: 0 auto 32px;
    font-weight: 300;
  }
</style>
