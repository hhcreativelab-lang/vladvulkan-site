---
import { DISCLAIMER } from '@lib/constants';

interface Props {
  variant?: 'inline' | 'box';
}

const { variant = 'box' } = Astro.props;
---

<div class:list={["disclaimer", variant]} role="note">
  <span class="dsc-mark" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10z"/><path d="m9 12 2 2 4-4"/>
    </svg>
  </span>
  <span><strong>Независимый эксперт.</strong> {DISCLAIMER.ru.replace('Независимый эксперт. ', '')}</span>
</div>

<style>
  .disclaimer {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.6;
    font-weight: 300;
  }
  .disclaimer.box {
    background: rgba(229, 198, 120, 0.04);
    border: 1px solid rgba(229, 198, 120, 0.18);
    border-radius: 4px;
    padding: 16px 20px;
    margin: 28px 0;
  }
  .disclaimer .dsc-mark {
    color: var(--gold-champagne);
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .dsc-mark svg { width: 100%; height: 100%; }
  .disclaimer strong { color: var(--gold-champagne); font-weight: 500; }
</style>
