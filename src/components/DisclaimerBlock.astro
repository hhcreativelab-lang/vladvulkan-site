---
import { DISCLAIMER } from '@lib/constants';

interface Props {
  variant?: 'inline' | 'box';
}

const { variant = 'box' } = Astro.props;
---

<div class:list={["disclaimer", variant]} role="note">
  <strong>Consultor inmobiliario.</strong>
  {DISCLAIMER.ru.replace('Consultor inmobiliario. ', '')}
</div>

<style>
  .disclaimer {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .disclaimer.box {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    margin: 24px 0;
  }

  .disclaimer.inline {
    margin: 12px 0;
  }
</style>
