---
import { CATEGORIES, type CategorySlug } from '@lib/constants';

interface Props {
  href: string;
  title: string;
  description: string;
  category: CategorySlug;
  pubDate?: Date;
}

const { href, title, description, category, pubDate } = Astro.props;
const cat = CATEGORIES[category];
const dateLabel = pubDate
  ? new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(pubDate)
  : null;
---

<a href={href} class="article-card card">
  <span class="cat-tag">{cat.short}</span>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  {dateLabel && <time class="card-date">{dateLabel}</time>}
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    height: 100%;
  }

  .cat-tag {
    display: inline-block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--accent-dark);
    background: var(--accent-light);
    padding: 4px 10px;
    border-radius: 999px;
    width: max-content;
    font-weight: 500;
  }

  .card-title {
    font-size: 17px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 6px 0 0;
  }

  .card-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .card-date {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 6px;
  }
</style>
