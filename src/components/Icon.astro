---
/**
 * Уникальный набор иконок, нарисованных под Влада Вулкана.
 * Стиль: тонкие линии 1.5, лёгкие акценты filled-fragments,
 * мягкие закругления, теплый акцент через currentColor + var(--warm).
 */
type IconName =
  | 'compass'      // подбор / навигация по рынку
  | 'shield-check' // due diligence
  | 'handshake'    // переговоры
  | 'document'     // escritura / договор
  | 'pin'          // география
  | 'gem'          // премиум-сегмент
  | 'key'          // ключи / закрытие сделки
  | 'chart'        // цены / аналитика
  | 'chat'         // консультация
  | 'globe'        // ЛатАм
  | 'star'         // отзыв
  | 'arrow-up-right'
  | 'send'         // telegram-style
  | 'spark';

interface Props {
  name: IconName;
  size?: number;
  stroke?: number;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 28, stroke = 1.5, class: className, ariaLabel } = Astro.props;
const ariaProps = ariaLabel
  ? { 'aria-label': ariaLabel, role: 'img' }
  : { 'aria-hidden': 'true' };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  class={className}
  {...ariaProps}
>
  {name === 'compass' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <circle cx="16" cy="16" r="13" />
      <path d="M21.5 10.5 18 18l-7.5 3.5L14 14z" fill="var(--warm-soft)" />
      <circle cx="16" cy="16" r="1.4" fill="currentColor" stroke="none" />
    </g>
  )}

  {name === 'shield-check' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 3 5 7v8c0 6 4.5 11 11 14 6.5-3 11-8 11-14V7z" fill="var(--accent-light)" />
      <path d="m11 16 3.5 3.5L21 12" stroke-width={stroke + 0.4} />
    </g>
  )}

  {name === 'handshake' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 14.5 9 9l4 1 3-2 4 2 5 2.5" fill="var(--warm-soft)" />
      <path d="m13 17 2.5 2.5a2 2 0 0 0 2.8-2.8L13 11l-3 3a2 2 0 0 0 2.8 2.8L16 14" />
      <path d="M19 14.5 22.5 18a2 2 0 1 1-2.8 2.8L17 18" />
    </g>
  )}

  {name === 'document' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 4h11l5 5v17a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" fill="var(--accent-lighter)" />
      <path d="M19 4v5h5" />
      <path d="M11 14h10" />
      <path d="M11 18h10" />
      <path d="M11 22q3-1 5 0t4 0" stroke="var(--warm-deep)" stroke-width={stroke + 0.4} />
    </g>
  )}

  {name === 'pin' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 28s-9-7.5-9-15a9 9 0 1 1 18 0c0 7.5-9 15-9 15z" fill="var(--warm-soft)" />
      <circle cx="16" cy="13" r="3.4" fill="var(--bg)" />
    </g>
  )}

  {name === 'gem' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 5h14l5 7-12 15L4 12z" fill="var(--accent-light)" />
      <path d="M4 12h24" />
      <path d="m9 5 4 7-3 0" />
      <path d="m23 5-4 7 3 0" />
      <path d="m13 12 3 15 3-15" />
    </g>
  )}

  {name === 'key' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <circle cx="10" cy="16" r="6" fill="var(--accent-light)" />
      <circle cx="10" cy="16" r="1.5" fill="currentColor" stroke="none" />
      <path d="M16 16h12" />
      <path d="M22 16v4" />
      <path d="M26 16v3" />
    </g>
  )}

  {name === 'chart' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 26h24" />
      <path d="M7 22V14" />
      <path d="M13 22V8" />
      <path d="M19 22v-6" />
      <path d="M25 22V12" />
      <path d="m4 14 9-9 6 6 9-7" stroke="var(--warm-deep)" stroke-width={stroke + 0.3} />
      <circle cx="13" cy="5" r="1.2" fill="var(--warm-deep)" stroke="none" />
      <circle cx="19" cy="11" r="1.2" fill="var(--warm-deep)" stroke="none" />
    </g>
  )}

  {name === 'chat' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 7a3 3 0 0 1 3-3h16a3 3 0 0 1 3 3v12a3 3 0 0 1-3 3h-9l-7 5v-5H8a3 3 0 0 1-3-3z" fill="var(--accent-lighter)" />
      <circle cx="11" cy="13" r="1.2" fill="currentColor" stroke="none" />
      <circle cx="16" cy="13" r="1.2" fill="currentColor" stroke="none" />
      <circle cx="21" cy="13" r="1.2" fill="currentColor" stroke="none" />
    </g>
  )}

  {name === 'globe' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <circle cx="16" cy="16" r="13" fill="var(--accent-light)" />
      <path d="M3 16h26" />
      <path d="M16 3c4 4 4 22 0 26" />
      <path d="M16 3c-4 4-4 22 0 26" />
    </g>
  )}

  {name === 'star' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 3 20 12l9 1.3-6.5 6.4L24.5 29 16 24l-8.5 5 2-9.3L3 13.3 12 12z" fill="var(--warm-soft)" />
    </g>
  )}

  {name === 'arrow-up-right' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 23 23 9" />
      <path d="M11 9h12v12" />
    </g>
  )}

  {name === 'send' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="m29 3-9 26-5-12-12-5z" fill="var(--accent-light)" />
      <path d="M29 3 14 18" />
    </g>
  )}

  {name === 'spark' && (
    <g stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 3v6M16 23v6M3 16h6M23 16h6M7 7l4 4M21 21l4 4M25 7l-4 4M11 21l-4 4" stroke="var(--warm-deep)" />
      <circle cx="16" cy="16" r="3" fill="var(--warm-soft)" />
    </g>
  )}
</svg>
