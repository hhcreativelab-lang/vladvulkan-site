---
import { SITE } from '@lib/constants';

interface Props {
  variant?: 'default' | 'compact';
}

const { variant = 'default' } = Astro.props;
---

<aside class:list={["author-card", variant]} aria-label="Об авторе">
  <div class="author-photo" aria-hidden="true">В</div>
  <div class="author-meta">
    <div class="author-name">{SITE.founder.nameRu}</div>
    <div class="author-role">
      Consultor inmobiliario · Эквадор · 13 лет в&nbsp;ЛатАм, 8+&nbsp;лет в&nbsp;недвижимости
    </div>
    <a href="/kto-ya" class="author-link">Подробнее об авторе →</a>
  </div>
</aside>

<style>
  .author-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin: 18px 0 28px;
  }

  .author-photo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-dark);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .author-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .author-role {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .author-link {
    margin-top: 4px;
    font-size: 13px;
    color: var(--accent-dark);
    width: max-content;
  }

  .compact .author-photo {
    width: 40px;
    height: 40px;
    font-size: 16px;
  }
</style>
