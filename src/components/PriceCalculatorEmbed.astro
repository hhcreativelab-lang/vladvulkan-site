---
interface Props {
  height?: string;
}

const { height = '1180px' } = Astro.props;
---

<div class="calc-embed">
  <span class="pillar-corner pc-tl"></span>
  <span class="pillar-corner pc-tr"></span>
  <span class="pillar-corner pc-bl"></span>
  <span class="pillar-corner pc-br"></span>
  <iframe
    src="/pricing-calculator.html"
    title="Калькулятор сопровождения сделки"
    loading="lazy"
    style={`height: ${height};`}
  ></iframe>
  <noscript>
    <p>Калькулятор требует JavaScript. <a href="/pricing-calculator.html">Открыть напрямую</a>.</p>
  </noscript>
</div>

<style>
  .calc-embed {
    position: relative;
    margin: 32px 0;
    border: 1px solid rgba(157, 127, 255, 0.12);
    border-radius: 8px;
    overflow: hidden;
    background: var(--midnight);
    backdrop-filter: blur(8px);
  }
  .calc-embed iframe {
    width: 100%;
    border: 0;
    display: block;
    background: var(--bg);
  }
  .calc-embed .pillar-corner { z-index: 2; }
  .calc-embed .pillar-corner::before, .calc-embed .pillar-corner::after { background: var(--gold-champagne); opacity: 0.5; }
</style>
