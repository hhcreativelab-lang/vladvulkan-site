---
import { SITE } from '@lib/constants';
import { breadcrumbListSchema } from '@lib/schema';

interface Props {
  items: Array<{ name: string; href: string }>;
}

const { items } = Astro.props;

const fullItems = [{ name: 'Главная', href: '/' }, ...items];
const schema = breadcrumbListSchema(
  fullItems.map((i) => ({
    name: i.name,
    url: i.href === '/' ? SITE.url : `${SITE.url}${i.href}`,
  })),
);
---

<nav class="breadcrumbs" aria-label="Хлебные крошки">
  <ol>
    {fullItems.map((item, i) => {
      const isLast = i === fullItems.length - 1;
      return (
        <li>
          {isLast ? (
            <span aria-current="page">{item.name}</span>
          ) : (
            <a href={item.href}>{item.name}</a>
          )}
          {!isLast && <span class="sep" aria-hidden="true">/</span>}
        </li>
      );
    })}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .breadcrumbs {
    margin: 28px 0 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-mute);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .breadcrumbs a {
    color: var(--text-mute);
    text-decoration: none;
    transition: color 0.3s;
  }
  .breadcrumbs a:hover { color: var(--gold-champagne); }
  .breadcrumbs .sep { color: var(--text-soft); opacity: 0.6; }
  .breadcrumbs [aria-current="page"] { color: var(--text-light); }
</style>
