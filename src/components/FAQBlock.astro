---
import { faqPageSchema } from '@lib/schema';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  title?: string;
  skipSchema?: boolean;
}

const { faqs, title = 'Частые вопросы', skipSchema = false } = Astro.props;
const schema = skipSchema ? null : faqPageSchema(faqs);
---

{faqs.length > 0 && (
  <section class="faq-block reveal" aria-labelledby="faq-heading">
    <div class="faq-head">
      <span class="eyebrow gold">FAQ</span>
      <h2 id="faq-heading">{title}</h2>
    </div>
    <div class="faq-list reveal-stagger">
      {faqs.map((faq, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>
            <span class="faq-q">{faq.question}</span>
            <span class="faq-toggle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 5v14M5 12h14"/>
              </svg>
            </span>
          </summary>
          <div class="faq-answer"><p>{faq.answer}</p></div>
        </details>
      ))}
    </div>
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </section>
)}

<style>
  .faq-block {
    margin: clamp(60px, 8vw, 100px) 0;
  }

  .faq-head {
    text-align: center;
    margin-bottom: 48px;
  }
  .faq-head .eyebrow { display: block; margin-bottom: 12px; }
  .faq-head h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 60px);
    margin: 0;
    color: var(--text-light);
    letter-spacing: -0.025em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: linear-gradient(180deg, rgba(22, 20, 26, 0.6) 0%, rgba(16, 14, 20, 0.75) 100%);
    border: 1px solid rgba(157, 127, 255, 0.08);
    border-radius: 4px;
    transition: border-color 0.4s var(--ease-premium);
    backdrop-filter: blur(8px);
  }
  .faq-item:hover { border-color: rgba(157, 127, 255, 0.2); }
  .faq-item[open] { border-color: rgba(157, 127, 255, 0.25); }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 26px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-q {
    font-family: var(--font-display);
    font-size: clamp(16px, 1.6vw, 19px);
    font-weight: 400;
    color: var(--text-light);
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .faq-toggle {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(229, 198, 120, 0.08);
    color: var(--gold-champagne);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s var(--ease-premium);
    border: 1px solid rgba(229, 198, 120, 0.2);
  }
  .faq-toggle svg { width: 14px; height: 14px; }
  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
    background: rgba(157, 127, 255, 0.15);
    color: var(--violet-bright);
    border-color: rgba(157, 127, 255, 0.4);
  }

  .faq-answer {
    padding: 0 26px 22px;
    color: var(--text-dim);
    font-size: 15px;
    line-height: 1.7;
    font-weight: 300;
  }
  .faq-answer p { margin: 0; }
</style>
