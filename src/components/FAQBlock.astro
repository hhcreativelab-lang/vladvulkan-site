---
import { faqPageSchema } from '@lib/schema';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  title?: string;
  /**
   * Если true — JSON-LD FAQPage НЕ рендерится здесь
   * (используйте, когда схема уже включена в SEO-блок страницы).
   */
  skipSchema?: boolean;
}

const { faqs, title = 'Часто задаваемые вопросы', skipSchema = false } = Astro.props;
const schema = skipSchema ? null : faqPageSchema(faqs);
---

{faqs.length > 0 && (
  <section class="faq-block" aria-labelledby="faq-heading">
    <h2 id="faq-heading">{title}</h2>
    <div class="faq-list">
      {faqs.map((faq, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>
            <h3>{faq.question}</h3>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </section>
)}

<style>
  .faq-block {
    margin: 48px 0;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 22px;
  }

  .faq-item {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: border-color 0.15s ease;
  }

  .faq-item[open] {
    border-color: var(--accent-mid);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 16px 20px;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item h3 {
    font-size: 16px;
    font-weight: 500;
    margin: 0;
    color: var(--text-primary);
  }

  .faq-toggle {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--bg-surface);
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
    transition: all 0.15s ease;
  }

  .faq-item[open] .faq-toggle {
    background: var(--accent-light);
    color: var(--accent-deep);
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 20px 18px;
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.6;
  }

  .faq-answer p {
    margin: 0;
  }
</style>
