---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import AuthorCard from '@components/AuthorCard.astro';
import FAQBlock from '@components/FAQBlock.astro';
import CTABlock from '@components/CTABlock.astro';
import DisclaimerBlock from '@components/DisclaimerBlock.astro';
import ArticleCard from '@components/ArticleCard.astro';
import { CATEGORIES, type CategorySlug } from '@lib/constants';
import { articleSchema, faqPageSchema } from '@lib/schema';
import { canonicalUrl } from '@lib/seo';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  category: CategorySlug;
  pubDate: Date;
  updatedDate: Date;
  ogImage?: string;
  shortAnswer?: string;
  keyNumbers?: string[];
  faq?: Array<{ question: string; answer: string }>;
  related?: string[];
}

const {
  title,
  description,
  category,
  pubDate,
  updatedDate,
  ogImage,
  shortAnswer,
  keyNumbers,
  faq,
  related,
} = Astro.props;

const cat = CATEGORIES[category];
const url = canonicalUrl(Astro.url.pathname);

const schemas: Array<Record<string, unknown>> = [
  articleSchema({ title, description, url, image: ogImage, datePublished: pubDate, dateModified: updatedDate, category }),
];
const faqSchema = faqPageSchema(faq ?? []);
if (faqSchema) schemas.push(faqSchema);

let relatedArticles: Array<{ id: string; data: { title: string; description: string; category: CategorySlug } }> = [];
if (related && related.length > 0) {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  relatedArticles = allArticles
    .filter((a) => related.includes(a.id))
    .map((a) => ({ id: a.id, data: { title: a.data.title, description: a.data.description, category: a.data.category } }));
}

const fmtDate = (d: Date) => new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---

<BaseLayout title={title} description={description} ogImage={ogImage} jsonLd={schemas}>
  <article class="article-page">
    <div class="container-narrow">
      <Breadcrumbs items={[
        { name: 'Знания', href: '/znaniya' },
        { name: cat.name, href: `/znaniya/${cat.slug}` },
        { name: title, href: Astro.url.pathname },
      ]} />

      <header class="article-header reveal">
        <span class="eyebrow gold">{cat.name}</span>
        <h1>{title}</h1>
        <p class="lead">{description}</p>
      </header>

      <AuthorCard />

      <div class="meta-row">
        <time datetime={pubDate.toISOString()}>Опубликовано: {fmtDate(pubDate)}</time>
        {updatedDate.getTime() !== pubDate.getTime() && (
          <time datetime={updatedDate.toISOString()}>Обновлено: {fmtDate(updatedDate)}</time>
        )}
      </div>

      {shortAnswer && (
        <div class="short-answer pillar reveal" role="note">
          <span class="pillar-corner pc-tl"></span><span class="pillar-corner pc-tr"></span>
          <span class="pillar-corner pc-bl"></span><span class="pillar-corner pc-br"></span>
          <span class="sa-eyebrow">Краткий ответ</span>
          <p>{shortAnswer}</p>
        </div>
      )}

      {keyNumbers && keyNumbers.length > 0 && (
        <div class="key-numbers reveal">
          <span class="kn-eyebrow">Главные цифры</span>
          <ul>
            {keyNumbers.map((n) => <li set:html={n} />)}
          </ul>
        </div>
      )}

      <div class="prose article-content">
        <slot />
      </div>

      {faq && faq.length > 0 && <FAQBlock faqs={faq} skipSchema />}

      {relatedArticles.length > 0 && (
        <section class="related" aria-labelledby="related-h">
          <span class="eyebrow gold">Дальше</span>
          <h2 id="related-h">Связанные статьи</h2>
          <div class="related-grid">
            {relatedArticles.map((a) => (
              <ArticleCard
                href={`/znaniya/${a.id}`}
                title={a.data.title}
                description={a.data.description}
                category={a.data.category}
              />
            ))}
          </div>
        </section>
      )}

      <CTABlock variant="info" />
      <DisclaimerBlock variant="box" />
    </div>
  </article>
</BaseLayout>

<style>
  .article-page { padding: 12px 0 40px; }

  .article-header {
    margin: 18px 0 16px;
  }
  .article-header .eyebrow { display: block; margin-bottom: 14px; }
  .article-header h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.5vw, 70px);
    line-height: 1.05;
    margin: 0 0 20px;
    letter-spacing: -0.025em;
  }
  .lead {
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0 0 12px;
    font-weight: 300;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-mute);
    margin-bottom: 28px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .short-answer {
    padding: 24px 28px;
    margin: 24px 0;
  }
  .sa-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
    margin-bottom: 8px;
  }
  .short-answer p {
    margin: 0;
    color: var(--text-light);
    font-size: 17px;
    line-height: 1.65;
    font-family: var(--font-display);
    font-weight: 400;
  }

  .key-numbers {
    background: linear-gradient(180deg, rgba(22, 20, 26, 0.6) 0%, rgba(16, 14, 20, 0.75) 100%);
    border: 1px solid rgba(229, 198, 120, 0.12);
    border-radius: 4px;
    padding: 22px 26px;
    margin: 24px 0 36px;
    backdrop-filter: blur(8px);
  }
  .kn-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-champagne);
    margin-bottom: 10px;
  }
  .key-numbers ul {
    margin: 0;
    padding-left: 22px;
    color: var(--text-dim);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
  }
  .key-numbers li { margin-bottom: 4px; }
  .key-numbers strong { color: var(--ivory); font-weight: 500; }

  .article-content { margin-top: 8px; }

  .related { margin: 60px 0 16px; }
  .related .eyebrow { display: block; margin-bottom: 12px; }
  .related h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
</style>
