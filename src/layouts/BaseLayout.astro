---
import '../styles/global.css';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { SITE } from '@lib/constants';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>> | null;
  noIndex?: boolean;
  includeBrandInTitle?: boolean;
  bodyClass?: string;
  /** transparent — для full-bleed hero страниц с overlay-навигацией */
  headerVariant?: 'default' | 'overlay';
  /** скрывает плавающую TG-кнопку (например на /kontakty) */
  hideFloatingTg?: boolean;
}

const {
  title,
  description,
  ogImage,
  jsonLd,
  noIndex,
  includeBrandInTitle,
  bodyClass,
  headerVariant = 'default',
  hideFloatingTg = false,
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Каталог знаний — Влад Вулкан" href="/rss.xml" />
    <meta name="theme-color" content="#070310" />
    <meta name="generator" content={Astro.generator} />

    <!-- Premium fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400;1,9..144,500&family=JetBrains+Mono:wght@300;400;500&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <SEO
      title={title}
      description={description}
      pathname={pathname}
      ogImage={ogImage}
      jsonLd={jsonLd}
      noIndex={noIndex}
      includeBrandInTitle={includeBrandInTitle}
    />
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">К основному контенту</a>

    <!-- Spotlight за курсором -->
    <div class="spotlight" id="spot" aria-hidden="true"></div>

    <!-- Scroll-rail справа -->
    <div class="scroll-rail" id="scrollRail" aria-hidden="true">
      <div class="scroll-arrow up"></div>
      <div class="scroll-track"><div class="scroll-progress" id="scrollProgress"></div></div>
      <div class="scroll-arrow down"></div>
      <div class="scroll-label">Scroll</div>
    </div>

    <Header variant={headerVariant} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- Плавающая Telegram-кнопка -->
    {!hideFloatingTg && (
      <a href={SITE.telegramUrl} class="tg-float" target="_blank" rel="noopener" aria-label="Написать в Telegram">
        <div class="tg-icon-wrap">
          <svg class="tg-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.05 2.434 2.42 9.9c-1.34.525-1.33 1.276-.242 1.606l5.05 1.577 11.688-7.372c.553-.334 1.057-.155.641.213L9.117 14.47l-.363 5.439c.523 0 .753-.24 1.046-.524l2.507-2.422 5.21 3.833c.96.528 1.65.256 1.889-.89l3.418-16.081c.349-1.405-.54-2.044-1.772-1.39"/>
          </svg>
          <span class="tg-online" aria-hidden="true"></span>
        </div>
        <span class="tg-label-main">Написать в&nbsp;Telegram</span>
      </a>
    )}

    <style>
      /* Scroll rail */
      .scroll-rail {
        position: fixed;
        right: 24px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 40;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        opacity: 0;
        transition: opacity 0.6s var(--ease-premium);
        pointer-events: none;
      }
      .scroll-rail.visible { opacity: 1; }
      .scroll-arrow {
        width: 8px;
        height: 8px;
        border-right: 1px solid var(--text-mute);
        border-bottom: 1px solid var(--text-mute);
        transition: all 0.4s;
        opacity: 0.3;
      }
      .scroll-arrow.up { transform: rotate(-135deg); }
      .scroll-arrow.down { transform: rotate(45deg); }
      .scroll-rail.going-down .scroll-arrow.down,
      .scroll-rail.going-up .scroll-arrow.up {
        border-color: var(--violet-bright);
        opacity: 1;
        box-shadow: 0 0 8px var(--violet-glow);
      }
      .scroll-track {
        width: 1px;
        height: 160px;
        background: rgba(157, 127, 255, 0.12);
        position: relative;
        overflow: hidden;
      }
      .scroll-progress {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 0;
        background: linear-gradient(180deg, var(--violet-bright), var(--violet));
        box-shadow: 0 0 8px var(--violet-glow);
        transition: height 0.2s linear;
      }
      .scroll-label {
        font-family: var(--font-mono);
        font-size: 9px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--text-mute);
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        margin-top: 4px;
      }
      @media (max-width: 900px) { .scroll-rail { display: none; } }

      /* Floating Telegram */
      .tg-float {
        position: fixed;
        left: 28px;
        bottom: 28px;
        z-index: 90;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 12px 22px 12px 14px;
        background: linear-gradient(135deg, #2D1B6B 0%, #1A0F47 50%, #0F0829 100%);
        border: 1px solid rgba(157, 127, 255, 0.3);
        border-radius: 60px;
        text-decoration: none;
        color: var(--text-light);
        font-family: var(--font-sans);
        box-shadow:
          0 8px 32px rgba(7, 3, 16, 0.5),
          0 0 24px rgba(106, 61, 232, 0.2),
          inset 0 1px 0 rgba(157, 127, 255, 0.2);
        transition: all 0.5s var(--ease-premium);
        animation: tgFloatIn 1s var(--ease-premium) 0.8s backwards;
      }
      @keyframes tgFloatIn {
        from { transform: translateY(80px) scale(0.8); opacity: 0; }
        to { transform: translateY(0) scale(1); opacity: 1; }
      }
      .tg-float:hover {
        border-color: var(--tg-blue);
        transform: translateY(-3px);
        color: var(--text-light);
        box-shadow:
          0 0 0 1px rgba(42, 171, 238, 0.4),
          0 12px 40px rgba(42, 171, 238, 0.25),
          0 0 60px rgba(42, 171, 238, 0.25),
          inset 0 1px 0 rgba(157, 127, 255, 0.3);
      }
      .tg-float:hover .tg-icon { color: var(--tg-blue); }
      .tg-icon-wrap {
        position: relative;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(42, 171, 238, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.4s;
      }
      .tg-float:hover .tg-icon-wrap { background: rgba(42, 171, 238, 0.2); }
      .tg-icon {
        width: 18px;
        height: 18px;
        color: var(--text-light);
        transition: color 0.4s;
      }
      .tg-online {
        position: absolute;
        top: -2px;
        right: -2px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--green);
        border: 2px solid #0F0829;
        box-shadow: 0 0 8px rgba(74, 222, 128, 0.8);
        animation: pulse 2s ease-in-out infinite;
      }
      .tg-label-main {
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-light);
        padding-right: 4px;
      }
      @media (max-width: 640px) {
        .tg-float { left: 16px; bottom: 16px; padding: 12px; }
        .tg-label-main { display: none; }
      }
    </style>

    <!-- Поведение: spotlight, sticky-nav, scroll-rail, reveal -->
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Spotlight
        const spot = document.getElementById('spot');
        if (spot && !reduced) {
          let raf = 0;
          let tx = window.innerWidth / 2, ty = window.innerHeight / 2;
          let x = tx, y = ty;
          window.addEventListener('mousemove', (e) => {
            tx = e.clientX; ty = e.clientY;
            if (!raf) raf = requestAnimationFrame(loop);
          }, { passive: true });
          function loop() {
            x += (tx - x) * 0.12;
            y += (ty - y) * 0.12;
            spot.style.left = x + 'px';
            spot.style.top = y + 'px';
            if (Math.abs(tx - x) > 0.5 || Math.abs(ty - y) > 0.5) {
              raf = requestAnimationFrame(loop);
            } else { raf = 0; }
          }
        }

        // Sticky-nav scrolled
        const header = document.querySelector('.site-header');
        const onHeaderScroll = () => {
          if (!header) return;
          if (window.scrollY > 30) header.classList.add('scrolled');
          else header.classList.remove('scrolled');
        };
        window.addEventListener('scroll', onHeaderScroll, { passive: true });
        onHeaderScroll();

        // Scroll rail
        const rail = document.getElementById('scrollRail');
        const progress = document.getElementById('scrollProgress');
        let lastY = 0;
        let dirTimeout = 0;
        window.addEventListener('scroll', () => {
          const y = window.scrollY;
          const docH = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docH > 0 ? Math.min(100, (y / docH) * 100) : 0;
          if (rail) {
            if (y > 100) rail.classList.add('visible');
            else rail.classList.remove('visible');
            if (y > lastY + 3) { rail.classList.add('going-down'); rail.classList.remove('going-up'); }
            else if (y < lastY - 3) { rail.classList.add('going-up'); rail.classList.remove('going-down'); }
          }
          if (progress) progress.style.height = pct + '%';
          lastY = y;
          clearTimeout(dirTimeout);
          dirTimeout = window.setTimeout(() => {
            if (rail) rail.classList.remove('going-down', 'going-up');
          }, 800);
        }, { passive: true });

        // Reveal на scroll
        if (!reduced && 'IntersectionObserver' in window) {
          const io = new IntersectionObserver((entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                io.unobserve(e.target);
              }
            }
          }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
          document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => io.observe(el));
        } else {
          document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => el.classList.add('visible'));
        }

        // Мировые часы
        function updateClocks() {
          const now = new Date();
          const fmt = (tz) => {
            try {
              return now.toLocaleTimeString('ru-RU', { timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false });
            } catch { return '—:—'; }
          };
          const set = (id, tz) => {
            const el = document.getElementById(id);
            if (el) el.textContent = fmt(tz);
          };
          set('t-cuenca', 'America/Guayaquil');
          set('t-moscow', 'Europe/Moscow');
          set('t-kyiv', 'Europe/Kyiv');
          set('t-berlin', 'Europe/Berlin');
          set('t-ny', 'America/New_York');
          set('t-toronto', 'America/Toronto');
        }
        updateClocks();
        setInterval(updateClocks, 30000);
      })();
    </script>
  </body>
</html>
